<Window x:Class="ArmZavuch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ArmZavuch.Models"
        Title="{Binding WindowTitle}"
        Icon="pack://application:,,,/Resources/AppIcon.png"
        Height="780"
        Width="1360"
        MinHeight="620"
        MinWidth="960"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <DockPanel Margin="0,12,0,12">
                <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <TextBlock Text="{Binding SaveStatusShort}" FontSize="14" HorizontalAlignment="Center"
                               Foreground="{Binding SaveStatusBrush}" ToolTip="{Binding SaveStatusText}"/>
                    <Button Content="💾" Command="{Binding SaveCommand}" Margin="0,8,0,0"
                            MinWidth="44" MinHeight="36" Padding="0"
                            ToolTip="Сохранить (Ctrl+S)"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding NavItems}" SelectedItem="{Binding SelectedNav}"
                         BorderThickness="0" Background="Transparent" HorizontalAlignment="Center">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarNavItemStyle}">
                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:NavEntry}">
                            <TextBlock Text="{Binding Icon}" FontSize="18" TextAlignment="Center"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="220">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Hint}" FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" Padding="16,12,16,12">
            <ContentControl Content="{Binding CurrentView}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>
