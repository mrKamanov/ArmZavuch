<UserControl x:Class="ArmZavuch.Views.ConstructorDayGridSectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:models="clr-namespace:ArmZavuch.Models"
             xmlns:views="clr-namespace:ArmZavuch.Views">
    <UserControl.Resources>
        <DataTemplate x:Key="ConstructorGridCellTemplate">
            <Border Width="96" Margin="2" Padding="4"
                    AllowDrop="True" Cursor="Hand"
                    MouseLeftButtonDown="Cell_MouseLeftButtonDown"
                    MouseMove="Cell_MouseMove"
                    MouseLeftButtonUp="Cell_MouseLeftButtonUp"
                    DragOver="Cell_DragOver"
                    DragLeave="Cell_DragLeave"
                    Drop="Cell_Drop">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="MinHeight" Value="52"/>
                        <Setter Property="VerticalAlignment" Value="Top"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBreakColumn}" Value="True">
                                <Setter Property="Background" Value="#FFF7ED"/>
                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                                <Setter Property="BorderThickness" Value="0.5"/>
                                <Setter Property="Height" Value="12"/>
                                <Setter Property="MinHeight" Value="12"/>
                                <Setter Property="MaxHeight" Value="12"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="2,0"/>
                                <Setter Property="AllowDrop" Value="False"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDynamicPauseColumn}" Value="True">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Setter Property="BorderBrush" Value="#86EFAC"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasRoomSharedWarning}" Value="True"/>
                                    <Condition Binding="{Binding HasConflict}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#FFFBEB"/>
                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding DragHintLevel}" Value="{x:Static models:DragHintLevel.Recommended}">
                                <Setter Property="Background" Value="#DCFCE7"/>
                                <Setter Property="BorderBrush" Value="#16A34A"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="360">
                                            <TextBlock Text="{Binding DragHintMessage}" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DragHintLevel}" Value="{x:Static models:DragHintLevel.Caution}">
                                <Setter Property="Background" Value="#FEF9C3"/>
                                <Setter Property="BorderBrush" Value="#CA8A04"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="360">
                                            <TextBlock Text="{Binding DragHintMessage}" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DragHintLevel}" Value="{x:Static models:DragHintLevel.Blocked}">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="360">
                                            <TextBlock Text="{Binding DragHintMessage}" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="BorderThickness" Value="2.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <ItemsControl ItemsSource="{Binding Parts}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBreakColumn}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,1">
                                <TextBlock Text="{Binding SubgroupLabel}" FontSize="8" FontWeight="Bold"
                                           Foreground="#64748B" HorizontalAlignment="Center"
                                           Visibility="{Binding SubgroupLabel, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                <TextBlock Text="{Binding SubjectName}" Foreground="#7C3AED" FontWeight="SemiBold"
                                           FontSize="9" TextAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding TeacherName}" Foreground="#0369A1"
                                           FontSize="9" TextAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding RoomLine}" FontSize="9" TextAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{Binding RoomBuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ItemsControl ItemsSource="{Binding Sections, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type models:ConstructorDayGridSection}">
                <StackPanel Margin="0,0,0,14">
                    <Border Background="#E2E8F0" CornerRadius="6" Padding="8,4" Margin="0,4,0,8"
                            Visibility="{Binding IsShiftHeader, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Left" Width="22" Height="22" Padding="0" Margin="0,0,8,0"
                                    FontSize="11" Cursor="Hand" VerticalAlignment="Center"
                                    Command="{Binding ViewModel.ToggleGridSectionCommand, RelativeSource={RelativeSource AncestorType=views:ConstructorDayGridSectionsView}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Свернуть или развернуть смену">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                        <Setter Property="MinWidth" Value="22"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding CollapseToggleGlyph}" HorizontalAlignment="Center"/>
                            </Button>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Visibility="{Binding IsShiftHeader, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                        <StackPanel Visibility="{Binding IsHiddenByParentShift, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                            <DockPanel Margin="0,0,0,6" LastChildFill="True">
                                <Button DockPanel.Dock="Left" Width="22" Height="22" Padding="0" Margin="0,0,6,0"
                                        FontSize="11" Cursor="Hand" VerticalAlignment="Top"
                                        Command="{Binding ViewModel.ToggleGridSectionCommand, RelativeSource={RelativeSource AncestorType=views:ConstructorDayGridSectionsView}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Свернуть или развернуть блок классов">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                            <Setter Property="MinWidth" Value="22"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding CollapseToggleGlyph}" HorizontalAlignment="Center"/>
                                </Button>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#475569">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Title}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomBellTrack}" Value="True">
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SubTitle}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                               Visibility="{Binding SubTitle, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                </StackPanel>
                            </DockPanel>

                            <StackPanel Visibility="{Binding IsGridVisible, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="4" Padding="2,4" Margin="2,0">
                                        <ItemsControl ItemsSource="{Binding BuildingBands}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{Binding BandWidth}" Margin="2,0" Padding="4,2"
                                                            CornerRadius="4" BorderThickness="1"
                                                            BorderBrush="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}">
                                                        <TextBlock Text="{Binding BuildingName}" FontSize="10" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Классы" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding ClassColumns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="96" Margin="2,0" Padding="4,3" Cursor="Hand"
                                                        Command="{Binding ViewModel.OpenClassWeekCommand, RelativeSource={RelativeSource AncestorType=views:ConstructorDayGridSectionsView}}"
                                                        CommandParameter="{Binding ClassId}"
                                                        ToolTip="Открыть расписание класса на неделю">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#93C5FD"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="bd" Property="Background" Value="#DBEAFE"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ClassName}" FontWeight="SemiBold" FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding DefaultRoomDisplay}" FontSize="8"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding LessonRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBreak}" Value="True">
                                                                <Setter Property="Margin" Value="0,0"/>
                                                                <Setter Property="Height" Value="14"/>
                                                                <Setter Property="MaxHeight" Value="14"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="88"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0" Padding="0"
                                                        Background="#FFF7ED"
                                                        Visibility="{Binding IsBreak, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                                    <TextBlock Text="{Binding RowTitle}" FontSize="8" FontWeight="SemiBold"
                                                               Foreground="#B45309" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"
                                                            Visibility="{Binding IsBreak, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDynamicPause}" Value="True">
                                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding RowTitle}" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding BellTimeDisplay}" FontSize="9" Foreground="{StaticResource MutedTextBrush}"/>
                                                </StackPanel>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}"
                                                              ItemTemplate="{StaticResource ConstructorGridCellTemplate}"
                                                              VerticalAlignment="Top">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
