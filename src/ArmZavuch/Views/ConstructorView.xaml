                                                                                               FontWeight="SemiBold" FontSize="9" TextAlignment="Center" TextWrapping="Wrap"/>
                                                                                    <TextBlock Text="{Binding TeacherName}" Foreground="#0369A1"
                                                                                               FontSize="9" TextAlignment="Center" TextWrapping="Wrap"/>
                                                                                    <TextBlock Text="{Binding RoomLine}" FontSize="9" TextAlignment="Center" TextWrapping="Wrap"
                                                                                               Foreground="{Binding RoomBuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Выберите класс в панели выше"
                                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                               Margin="0,12,0,0" HorizontalAlignment="Center"
                                               Visibility="{Binding FocusClass, Converter={x:Static conv:InverseNullToCollapsedConverter.Instance}}"/>
                                </StackPanel>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                        </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Период" ToolTip="Когда действует расписание: триместры, модули, чередование А/Б">
                <controls:ScrollableTabContent Padding="12,8,12,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                            CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock Text="{Binding PeriodOverlapHint}" FontSize="11" Foreground="#0369A1"
                                   TextWrapping="Wrap" LineHeight="16"/>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380" MinWidth="340"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CrudFormPanelStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Период действия расписания" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,10">
                                <TextBlock Text="{Binding PeriodFormHint}" Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                            </Border>
                            <TextBlock Text="Название" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Text="{Binding PeriodName}" Margin="0,0,0,10"
                                     ToolTip="Как период будет в списке — например: 1 модуль, I четверть"/>
                            <TextBlock Text="Тип периода" Style="{StaticResource FormFieldLabelStyle}"/>
                            <ComboBox SelectedValue="{Binding SelectedPeriodType}" SelectedValuePath="Tag" Margin="0,0,0,10"
                                      ToolTip="Модуль — короткий период внутри триместра; при пересечении дат действует более короткий">
                                <ComboBoxItem Content="Четверть" Tag="Quarter"/>
                                <ComboBoxItem Content="Модуль" Tag="Module"/>
                                <ComboBoxItem Content="Триместр" Tag="Trimester"/>
                                <ComboBoxItem Content="Полугодие" Tag="HalfYear"/>
                                <ComboBoxItem Content="Учебный год" Tag="Year"/>
                            </ComboBox>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Дата начала" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <DatePicker Style="{StaticResource SidePanelDatePickerStyle}"
                                                SelectedDate="{Binding PeriodStart}"
                                                ToolTip="Первый день периода включительно"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Дата окончания" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <DatePicker Style="{StaticResource SidePanelDatePickerStyle}"
                                                SelectedDate="{Binding PeriodEnd}"
                                                ToolTip="Последний день периода включительно"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Чередование шаблонов" Style="{StaticResource FormFieldLabelStyle}"/>
                            <ComboBox SelectedValue="{Binding SelectedRecurrence}" SelectedValuePath="Tag" Margin="0,0,0,6"
                                      ToolTip="Как выбирать шаблон недели на даты этого периода">
                                <ComboBoxItem Content="Каждую неделю" Tag="EveryWeek"/>
                                <ComboBoxItem Content="Через неделю (А/Б)" Tag="EveryOtherWeek"/>
                            </ComboBox>
                            <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,12">
                                <TextBlock Text="{Binding PeriodRecurrenceHint}" Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                            </Border>
                            <Border Style="{StaticResource ToolbarButtonGroupStyle}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource ToolbarGroupPrimaryItemStyle}"
                                            Command="{Binding SavePeriodCommand}"
                                            ToolTip="Добавить новый период или сохранить правки">
                                        <TextBlock Text="{Binding SavePeriodLabel}" VerticalAlignment="Center"/>
                                    </Button>
                                    <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                                    <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                            Command="{Binding DeletePeriodCommand}"
                                            ToolTip="Удалить выбранный период (Delete)">
                                        <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                    </Button>
                                    <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                                    <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                            Command="{Binding CancelEditCommand}"
                                            ToolTip="Сбросить форму для новой записи">
                                        <TextBlock Text="Отмена" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Column="2" ItemsSource="{Binding Periods}" AutoGenerateColumns="False" IsReadOnly="True"
                              Style="{StaticResource CrudDataGridStyle}"
                              CanUserResizeColumns="True"
                              SelectedItem="{Binding SelectedPeriod}"
                              helpers:DataGridCrudBehaviors.EditRowCommand="{Binding EditPeriodRowCommand}"
                              helpers:DataGridCrudBehaviors.DeleteRowCommand="{Binding DeletePeriodRowCommand}">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding DeletePeriodCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource CurriculumLoadDataGridRowStyle}">
                                <Setter Property="ToolTip" Value="{Binding RowToolTip}"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="40"
                                                    HeaderTemplate="{StaticResource DataGridCheckboxHeaderTemplate}"
                                                    CellTemplate="{StaticResource DataGridCheckboxCellTemplate}"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*" MinWidth="100"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding PeriodTypeDisplay}" Width="100" MinWidth="80"/>
                            <DataGridTextColumn Header="С" Binding="{Binding StartDateDisplay}" Width="100" MinWidth="90"/>
                            <DataGridTextColumn Header="По" Binding="{Binding EndDateDisplay}" Width="100" MinWidth="90"/>
                            <DataGridTextColumn Header="Чередование" Binding="{Binding RecurrenceCycleDisplay}" Width="*" MinWidth="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="ToolTip" Value="{Binding RecurrenceCycleDisplay}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="68" CellTemplate="{StaticResource DataGridRowActionsTemplate}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Grid>
                </Grid>
                </controls:ScrollableTabContent>
            </TabItem>

            <TabItem Header="Проверка норм" ToolTip="Замечания к сетке, СанПиН и сравнение нагрузки с программой">
                <controls:ScrollableTabContent Padding="12,8,12,16">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Проверка сетки и нагрузки" FontWeight="SemiBold"/>
                            <TextBlock Text="Слева — замечания к сетке (накладки и предупреждения). Справа — сверка часов в справочнике с типовой программой. Красное — накладка, жёлтое — замечание, синее — справка."
                                       Style="{StaticResource FormFieldLabelStyle}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="8"
                                        Padding="10,6" Margin="0,0,8,0"
                                        Visibility="{Binding HasComplianceFindings, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                                    <TextBlock Text="Замечаний к сетке нет" FontSize="12" FontWeight="SemiBold" Foreground="#15803D"/>
                                </Border>
                                <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8"
                                        Padding="10,6" Margin="0,0,8,0"
                                        Visibility="{Binding ComplianceErrorCount, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#B91C1C">
                                        <Run Text="Накладок: "/>
                                        <Run Text="{Binding ComplianceErrorCount, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="8"
                                        Padding="10,6" Margin="0,0,8,0"
                                        Visibility="{Binding ComplianceWarningCount, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#B45309">
                                        <Run Text="Замечаний: "/>
                                        <Run Text="{Binding ComplianceWarningCount, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8"
                                        Padding="10,6" Margin="0,0,8,0"
                                        Visibility="{Binding ComplianceInfoCount, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8">
                                        <Run Text="Справок: "/>
                                        <Run Text="{Binding ComplianceInfoCount, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <WrapPanel>
                                <Button Content="Проверить снова" Command="{Binding RefreshComplianceCommand}" Margin="0,0,0,8"
                                        ToolTip="Пересчитать замечания по СанПиН и методике. Сетку не меняет."/>
                            </WrapPanel>
                            <TextBlock Text="Сверка «нагрузка ↔ сетка» — на вкладке «Сетка», панель «Сетка vs нагрузка». Часы по программе (ФОП) — в «Справочники → Нагрузка»."
                                       FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ComplianceActionMessage}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#1D4ED8" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Grid Margin="0,8,0,0">
                        <Border Style="{StaticResource DirectorySidePanelStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Замечания к сетке" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock DockPanel.Dock="Top" Text="{Binding ComplianceSummary}" FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock DockPanel.Dock="Top" Text="{Binding ComplianceFilterSummary}" FontSize="11"
                                           Foreground="#1D4ED8" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <CheckBox Content="Накладки" IsChecked="{Binding ComplianceShowErrors}" Margin="0,0,10,4" VerticalAlignment="Center"/>
                                    <CheckBox Content="Замечания" IsChecked="{Binding ComplianceShowWarnings}" Margin="0,0,10,4" VerticalAlignment="Center"/>
                                    <CheckBox Content="Справки" IsChecked="{Binding ComplianceShowInfo}" Margin="0,0,10,4" VerticalAlignment="Center"/>
                                    <TextBlock Text="Класс:" VerticalAlignment="Center" Margin="0,0,4,4" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ClassList}" SelectedItem="{Binding ComplianceFilterClass}"
                                              Width="88" Margin="0,0,10,4" ToolTip="Показать замечания только для выбранного класса">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,4,4" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <TextBox Width="120" Text="{Binding ComplianceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,10,4" ToolTip="Фильтр по тексту замечания"/>
                                    <ComboBox Width="130" SelectedValue="{Binding ComplianceSortMode}" SelectedValuePath="Tag"
                                              Margin="0,0,0,4" ToolTip="Сортировка списка">
                                        <ComboBoxItem Content="Важность" Tag="Severity"/>
                                        <ComboBoxItem Content="Класс и день" Tag="ClassDay"/>
                                        <ComboBoxItem Content="Тип замечания" Tag="Code"/>
                                    </ComboBox>
                                </WrapPanel>
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <CheckBox Content="Показать скрытые" IsChecked="{Binding ComplianceShowDismissed}" Margin="0,0,10,0"/>
                                    <Button Content="Вернуть скрытые" Command="{Binding RestoreDismissedComplianceCommand}" Margin="0,0,8,0"
                                            Visibility="{Binding ComplianceDismissedCount, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}"/>
                                    <Button Content="Сбросить фильтры" Command="{Binding ResetComplianceFiltersCommand}"/>
                                </WrapPanel>
                                <ListView ItemsSource="{Binding ComplianceIssues}" BorderThickness="0" Background="Transparent"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          HorizontalContentAlignment="Stretch">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,6"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ComplianceIssue}">
                                            <Border CornerRadius="8" BorderThickness="1" Padding="10,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                        <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ComplianceSeverity.Error}">
                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                                <Setter Property="BorderBrush" Value="#FECACA"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ComplianceSeverity.Warning}">
                                                                <Setter Property="Background" Value="#FFFBEB"/>
                                                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*" MinWidth="0"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="6" Padding="8,4" VerticalAlignment="Top" Margin="0,0,10,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ComplianceSeverity.Error}">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ComplianceSeverity.Warning}">
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding SeverityLabel}" FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ComplianceSeverity.Error}">
                                                                            <Setter Property="Foreground" Value="#B91C1C"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ComplianceSeverity.Warning}">
                                                                            <Setter Property="Foreground" Value="#B45309"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.OpenComplianceIssueCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </StackPanel.InputBindings>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanNavigate}" Value="False">
                                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding ContextLine}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,4"
                                                                   Visibility="{Binding HasContext, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                                        <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextBrush}" LineHeight="18"/>
                                                        <TextBlock Text="{Binding NavigationHint}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#1D4ED8" Margin="0,6,0,0"
                                                                   Visibility="{Binding CanNavigate, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="✕" Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                                                            VerticalAlignment="Top" ToolTip="Скрыть из списка"
                                                            Command="{Binding DataContext.DismissComplianceIssueCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
                </controls:ScrollableTabContent>
            </TabItem>

            <TabItem Header="Графики Сивкова"
                     ToolTip="Сумма баллов Сивкова по дням для каждого класса текущего шаблона">
                <controls:ScrollableTabContent Padding="12,8,12,16">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding SivkovChartsHint}" Style="{StaticResource SidePanelHelpTextStyle}"/>
                                <TextBlock Text="{Binding SivkovChartsSummary}" FontWeight="SemiBold"
                                           Foreground="#1E40AF" Margin="0,6,0,0" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border DockPanel.Dock="Top" Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                CornerRadius="6" Padding="8,6" Margin="0,0,0,10"
                                Visibility="{Binding HasClassWorkloadCharts, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                            <TextBlock Text="Нет данных для графиков — выберите шаблон недели и разложите уроки."
                                       FontSize="11" Foreground="#92400E" TextWrapping="Wrap"/>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ClassWorkloadCharts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="504" Margin="0,0,12,12" Padding="12,10"
                                                CornerRadius="10" Background="#F8FAFC" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDailyOverload}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                            <Setter Property="Background" Value="#FFFBEB"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding ClassName}"
                                                               FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="⚠ день" FontSize="10"
                                                               Foreground="#B45309" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasDailyOverload, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding SummaryLine}" FontSize="10"
                                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                                                <controls:WeeklyLoadChartSurface Points="{Binding Points}"
                                                                                   PolylinePoints="{Binding PolylinePoints}"
                                                                                   PlotWidth="480" PlotHeight="120"
                                                                                   IsLarge="True"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </controls:ScrollableTabContent>
            </TabItem>

            <TabItem Header="Календарь" ToolTip="Каникулы, праздники, субботы">
                <controls:ScrollableTabContent Padding="12,8,12,16">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}" MaxWidth="520" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Учебный календарь" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,10">
                                <TextBlock Text="{Binding CalendarFormHint}" Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                            </Border>
                            <TextBlock Text="Тип события" Style="{StaticResource FormFieldLabelStyle}"/>
                            <ComboBox SelectedValue="{Binding SelectedCalType}" SelectedValuePath="Tag" Margin="0,0,0,10"
                                      ToolTip="Праздник — один день; каникулы — диапазон; суббота с уроками — компенсация">
                                <ComboBoxItem Content="Праздник / выходной" Tag="Holiday"/>
                                <ComboBoxItem Content="Каникулы" Tag="Vacation"/>
                                <ComboBoxItem Content="Компенсационная суббота" Tag="Compensation"/>
                            </ComboBox>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Дата начала" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <DatePicker Style="{StaticResource SidePanelDatePickerStyle}"
                                                SelectedDate="{Binding CalStartDate}"
                                                ToolTip="Первый день события — для праздника это и есть нужная дата"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Дата окончания" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <DatePicker Grid.Column="0" Style="{StaticResource SidePanelDatePickerStyle}"
                                                    SelectedDate="{Binding CalEndDate}"
                                                    ToolTip="Для каникул — последний день; для одного праздника оставьте пустым"/>
                                        <Button Grid.Column="1" Content="Очистить"
                                                Command="{Binding ClearCalEndDateCommand}"
                                                Style="{StaticResource SmallButtonStyle}"
                                                Margin="6,0,0,0" VerticalAlignment="Center"
                                                ToolTip="Один день вместо периода — сбросить дату окончания"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Заметка" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Text="{Binding CalNote}" Margin="0,0,0,10"
                                     ToolTip="Подпись для себя — например «Осенние каникулы» или «День учителя»"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                                        Visibility="{Binding IsCalDonorDayVisible, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                <TextBlock Text="Перенос с дня:" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Style="{StaticResource FormFieldLabelStyle}"
                                           ToolTip="С какого буднего дня берётся расписание на компенсационную субботу"/>
                                <ComboBox Width="52" SelectedIndex="{Binding CalDonorDayIndex}"
                                          ToolTip="День недели, с которого переносятся уроки">
                                    <ComboBoxItem Content="Пн"/>
                                    <ComboBoxItem Content="Вт"/>
                                    <ComboBoxItem Content="Ср"/>
                                    <ComboBoxItem Content="Чт"/>
                                    <ComboBoxItem Content="Пт"/>
                                    <ComboBoxItem Content="Сб"/>
                                </ComboBox>
                            </StackPanel>
                            <Border Style="{StaticResource ToolbarButtonGroupStyle}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource ToolbarGroupPrimaryItemStyle}"
                                            Command="{Binding SaveCalendarCommand}"
                                            ToolTip="Добавить событие или сохранить правки">
                                        <TextBlock Text="{Binding SaveCalendarLabel}" VerticalAlignment="Center"/>
                                    </Button>
                                    <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                                    <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                            Command="{Binding DeleteCalendarCommand}"
                                            ToolTip="Удалить выбранное событие (Delete)">
                                        <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                    </Button>
                                    <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                                    <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                            Command="{Binding CancelEditCommand}"
                                            ToolTip="Очистить форму">
                                        <TextBlock Text="Отмена" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding CalendarEntries}" AutoGenerateColumns="False" IsReadOnly="True"
                              Style="{StaticResource CrudDataGridStyle}"
                              SelectedItem="{Binding SelectedCalendarEntry}"
                              helpers:DataGridCrudBehaviors.EditRowCommand="{Binding EditCalendarRowCommand}"
                              helpers:DataGridCrudBehaviors.DeleteRowCommand="{Binding DeleteCalendarRowCommand}">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding DeleteCalendarCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="40"
                                                    HeaderTemplate="{StaticResource DataGridCheckboxHeaderTemplate}"
                                                    CellTemplate="{StaticResource DataGridCheckboxCellTemplate}"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="100"/>
                            <DataGridTextColumn Header="С" Binding="{Binding StartDate}" Width="90"/>
                            <DataGridTextColumn Header="По" Binding="{Binding EndDate}" Width="90"/>
                            <DataGridTextColumn Header="Заметка" Binding="{Binding Note}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="68" CellTemplate="{StaticResource DataGridRowActionsTemplate}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
                </controls:ScrollableTabContent>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="1" Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"
                      Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}"/>

        <DockPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" LastChildFill="True"
                   Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
            <Border DockPanel.Dock="Bottom" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                    CornerRadius="8" Padding="8,6" Margin="0,8,0,0">
                <TextBlock Text="{Binding ContextHelpTip}" FontSize="10" Foreground="#0369A1"
                           TextWrapping="Wrap" LineHeight="14"/>
            </Border>

            <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}" Margin="0,0,0,8"
                    Visibility="{Binding IsScheduleTab, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CellEditorTitle}" FontWeight="SemiBold"
                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                   ToolTip="Укажите предмет и учителя; кабинет — если нужен для урока"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <TextBlock Text="П/г" VerticalAlignment="Center" Margin="0,0,4,0"
                                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                            <ComboBox Width="44" SelectedIndex="{Binding SelectedSubgroupIndex}"
                                      ToolTip="Переключите 1 или 2, заполните поля и сохраните — обе подгруппы останутся в одной ячейке">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding SubgroupEditorHint}" FontSize="10" Foreground="#1D4ED8"
                               TextWrapping="Wrap" Margin="0,0,0,6"
                               Visibility="{Binding SubgroupEditorHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    <Border Style="{StaticResource ConstructorAccentFieldShellStyle}" Background="#F5F3FF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6,0,0,6"
                                    Background="{StaticResource ConstructorSubjectAccentBrush}"/>
                            <StackPanel Grid.Column="1" Margin="8,6,8,6">
                                <TextBlock Text="Предмет" Style="{StaticResource ConstructorAccentFieldLabelStyle}"
                                           Foreground="{StaticResource ConstructorSubjectAccentBrush}"/>
                                <ComboBox ItemsSource="{Binding SubjectList}" DisplayMemberPath="Name"
                                          Style="{StaticResource ConstructorAccentFieldComboStyle}"
                                          SelectedItem="{Binding EditSubject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="False"
                                          IsTextSearchEnabled="True"
                                          TextSearch.TextPath="Name"
                                          ToolTip="Выберите предмет из списка (в открытом списке можно набирать буквы для поиска)"/>
                                <TextBox Text="{Binding SubjectSearchText, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,4,0,0"
                                           ToolTip="Если предмета нет в списке — введите название вручную"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                Visibility="{Binding SubjectSuggestionHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                        <TextBlock Text="{Binding SubjectSuggestionHint}" FontSize="10"
                                   Foreground="#B45309" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Content="Применить" Style="{StaticResource SmallButtonStyle}" Margin="6,0,0,0"
                                Command="{Binding ApplySubjectSuggestionCommand}"
                                ToolTip="Подставить предложенное название"/>
                    </StackPanel>
                    <Border Style="{StaticResource ConstructorAccentFieldShellStyle}" Background="#EFF6FF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6,0,0,6"
                                    Background="{StaticResource ConstructorTeacherAccentBrush}"/>
                            <StackPanel Grid.Column="1" Margin="8,6,8,6">
                                <TextBlock Text="Учитель" Style="{StaticResource ConstructorAccentFieldLabelStyle}"
                                           Foreground="{StaticResource ConstructorTeacherAccentBrush}"/>
                                <ComboBox ItemsSource="{Binding TeacherPickerView}" DisplayMemberPath="DisplayName"
                                          Style="{StaticResource ConstructorAccentFieldComboStyle}"
                                          SelectedItem="{Binding SelectedTeacherPickerItem}"
                                          ToolTip="Сверху — учителя, привязанные к этому классу; ниже — остальные">
                                    <ComboBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource ConstructorTeacherAccentBrush}"
                                                               Margin="4,4,0,0" FontSize="11"/>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ComboBox.GroupStyle>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource ConstructorAccentFieldShellStyle}"
                            Background="{Binding EditRoomBuildingColorHex, Converter={x:Static conv:HexToLightBrushConverter.Instance}, ConverterParameter=0.14}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6,0,0,6"
                                    Background="{Binding EditRoomBuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                            <StackPanel Grid.Column="1" Margin="8,6,8,6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Кабинет" Style="{StaticResource ConstructorAccentFieldLabelStyle}"
                                               Foreground="{Binding EditRoomBuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                    <TextBlock Text=" (необязательно)" FontSize="11" Foreground="#64748B" Margin="4,0,0,0"
                                               Visibility="{Binding IsEditRoomRequired, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding RoomList}"
                                          Style="{StaticResource ConstructorAccentFieldComboStyle}"
                                          SelectedItem="{Binding EditRoom}"
                                          ToolTip="{Binding EditRoomHint}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                        Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="{Binding Number}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding BuildingName}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                    <Button Grid.Column="1" Content="Убрать"
                                            Command="{Binding ClearEditRoomCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="6,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding EditRoom, Converter={x:Static conv:NullToCollapsedConverter.Instance}}"
                                            ToolTip="Снять кабинет с урока (прогулка, дин. пауза и др.)"/>
                                </Grid>
                                <TextBlock Text="{Binding EditRoomHint}" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                            CornerRadius="6" Padding="6,4" Margin="0,0,0,6"
                            Visibility="{Binding HasEditConflict, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Foreground="#B91C1C" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap">
                                <Run Text="⚠ "/>
                                <Run Text="{Binding EditConflictSummary}"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding EditConflictMessages}" Margin="0,2,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#991B1B"
                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                            CornerRadius="6" Padding="6,4" Margin="0,0,0,6"
                            Visibility="{Binding HasEditRoomSharedWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Foreground="#92400E" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap">
                                <Run Text="🏃 "/>
                                <Run Text="{Binding EditRoomSharedSummary}"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding EditRoomSharedMessages}" Margin="0,2,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#78350F"
                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                            CornerRadius="6" Padding="6,4" Margin="0,0,0,6"
                            Visibility="{Binding HasEditTransitionWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Foreground="#92400E" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap">
                                <Run Text="↔ "/>
                                <Run Text="{Binding EditTransitionSummary}"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding EditTransitionMessages}" Margin="0,2,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#78350F"
                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1"
                            CornerRadius="6" Padding="6,4" Margin="0,0,0,6"
                            Visibility="{Binding HasEditUnavailabilityWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Foreground="#9A3412" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap">
                                <Run Text="🕐 "/>
                                <Run Text="{Binding EditUnavailabilitySummary}"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding EditUnavailabilityMessages}" Margin="0,2,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#7C2D12"
                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolbarButtonGroupStyle}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource ToolbarGroupPrimaryItemStyle}"
                                    Command="{Binding SaveCellCommand}"
                                    ToolTip="Записать урок в выбранную ячейку">
                                <TextBlock Text="✓ Сохранить" VerticalAlignment="Center"/>
                            </Button>
                            <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                            <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                    Command="{Binding ClearCellCommand}"
                                    ToolTip="Удалить все уроки в ячейке, включая обе подгруппы (Delete)">
                                <TextBlock Text="⊘ Очистить" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DirectorySidePanelStyle}" MinHeight="72"
                    Visibility="{Binding IsScheduleTab, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Сетка vs нагрузка" FontWeight="SemiBold"
                                       ToolTip="Сравнение часов в справочнике «Нагрузка» и уроков в текущей сетке"/>
                            <TextBlock Text="{Binding BalancePanelSummary}" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{Binding BalanceToggleLabel}"
                                Command="{Binding ToggleShowAllBalanceCommand}"
                                Style="{StaticResource SmallButtonStyle}" VerticalAlignment="Top"
                                ToolTip="По умолчанию — только предметы с расхождением"/>
                    </Grid>
                    <Border DockPanel.Dock="Top" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
                            CornerRadius="6" Padding="6,4" Margin="0,0,0,6"
                            Visibility="{Binding ShowBalanceEmptyHint, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding BalanceEmptyHint}" FontSize="10" Foreground="#166534" TextWrapping="Wrap"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding BalanceView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4" Padding="6,4" CornerRadius="6"
                                            Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenBalanceRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                                        <Setter Property="Background" Value="#FFFBEB"/>
                                                        <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock FontSize="10" Margin="0,1,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}">
                                                <Run Text="{Binding HoursLine, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DeltaLine}" FontSize="10" Foreground="#B45309"
                                                       Margin="0,1,0,0"
                                                       Visibility="{Binding DeltaLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                            <TextBlock Text="{Binding NavigationHint}" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#1D4ED8" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
