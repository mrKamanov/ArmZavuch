                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,6,0"
                                                                    Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
