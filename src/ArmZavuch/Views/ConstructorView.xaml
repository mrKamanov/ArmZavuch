                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ItemsControl.Style>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel Margin="0,0,0,1">
                                                                                    <TextBlock Text="{Binding SubgroupLabel}" FontSize="8" FontWeight="Bold"
                                                                                               Foreground="#64748B" HorizontalAlignment="Center"
                                                                                               Visibility="{Binding SubgroupLabel, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
