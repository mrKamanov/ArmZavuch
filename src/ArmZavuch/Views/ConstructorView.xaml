<UserControl x:Class="ArmZavuch.Views.ConstructorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:helpers="clr-namespace:ArmZavuch.Views.Helpers"
             xmlns:controls="clr-namespace:ArmZavuch.Views.Controls"
             xmlns:views="clr-namespace:ArmZavuch.Views"
             xmlns:models="clr-namespace:ArmZavuch.Models"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoLastCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClearCheckboxSelectionCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="360"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition MinWidth="0" MaxWidth="380"
                              Width="{Binding IsGridFullscreen, Converter={x:Static conv:BoolToGridLengthConverter.Instance}, ConverterParameter=0|280}"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource ModuleHeaderBarStyle}"
                Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Конструктор" Style="{StaticResource ModulePageTitleStyle}"/>
                    <TextBlock Text="{Binding HeaderHint}" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource ToolbarButtonGroupStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                Command="{Binding UndoLastCommand}"
                                IsEnabled="{Binding CanUndo}"
                                ToolTip="Отменить последнее действие (Ctrl+Z)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↩" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Отменить" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                        <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                Command="{Binding LoadCommand}"
                                ToolTip="Перечитать шаблоны, классы и сетку из базы">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Обновить" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Grid.Column="0" Margin="0,0,0,0"
                    SelectedIndex="{Binding ActiveTabIndex}">
            <TabControl.Style>
                <Style TargetType="TabControl" BasedOn="{StaticResource ModuleTabControlStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGridFullscreen}" Value="True">
                            <Setter Property="Padding" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModuleTabItemStyle}"/>
            </TabControl.Resources>

            <TabItem Header="Сетка" ToolTip="Недельный шаблон: уроки по классам и дням">
                <DockPanel Margin="12,8,12,0" LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}" Padding="8,6" Margin="0,0,0,6"
                            Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <WrapPanel VerticalAlignment="Center">
                            <Button Content="Свернуть" Command="{Binding ToggleGridFullscreenCommand}"
                                    Style="{StaticResource SmallButtonStyle}" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding HeaderHint}" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </WrapPanel>
                    </Border>
                    <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}" Padding="10,8" Margin="0,0,0,6"
                            Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <Border Style="{StaticResource ToolbarButtonGroupStyle}" Margin="0,0,8,4"
                                        ToolTip="Шаблон недели — полное расписание на одну неделю (А/Б или каждую неделю)">
                                    <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}"
                                             BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" ToolTip="{Binding TabHint}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,5"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bd" Background="Transparent"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                                <Button Style="{StaticResource ToolbarGroupItemStyle}" Margin="0,0,4,4"
                                        Command="{Binding CreateTemplateCommand}"
                                        ToolTip="Создать пустой шаблон — название «Неделя А», «Б», «В»…">
                                    <TextBlock Text="＋" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarGroupItemStyle}" Margin="0,0,4,4"
                                        Command="{Binding CopyTemplateCommand}"
                                        ToolTip="Копия шаблона — предложит следующую букву (А→Б→В…)">
                                    <TextBlock Text="⎘" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarGroupItemStyle}" Margin="0,0,10,4"
                                        Command="{Binding DeleteTemplateCommand}" ToolTip="Удалить шаблон">
                                    <TextBlock Text="🗑" FontSize="13" Foreground="{StaticResource DangerBrush}"/>
                                </Button>

                                <ComboBox SelectedValue="{Binding GridViewMode, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag" MinWidth="168" FontSize="11" Margin="0,0,8,4"
                                          ToolTip="{Binding GridViewModeHint}">
                                    <ComboBoxItem Content="Все классы · день" Tag="AllClassesDay"/>
                                    <ComboBoxItem Content="Все классы · неделя" Tag="AllClassesWeek"/>
                                    <ComboBoxItem Content="Один класс · неделя" Tag="SingleClassWeek"/>
                                </ComboBox>

                                <Border Style="{StaticResource ToolbarButtonGroupStyle}" Margin="0,0,8,4"
                                        Visibility="{Binding IsAllClassesDayMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                        ToolTip="День недели в сетке">
                                    <ListBox ItemsSource="{Binding DayNames}" SelectedIndex="{Binding SelectedDayIndex}"
                                             BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="8,4"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bd" Background="Transparent"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>

                                <ComboBox ItemsSource="{Binding ClassList}" SelectedItem="{Binding FocusClass}"
                                          MinWidth="72" FontSize="11" Margin="0,0,8,4"
                                          Visibility="{Binding IsSingleClassWeekMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                          ToolTip="Класс для недельного режима">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <ComboBox ItemsSource="{Binding RoomList}" SelectedItem="{Binding FocusClassDefaultRoom}"
                                          MinWidth="120" FontSize="11" Margin="0,0,8,4"
                                          Visibility="{Binding IsSingleClassWeekMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                          ToolTip="Кабинет по умолчанию для новых ячеек этого класса">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                        Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="{Binding Number}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding BuildingName}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <ComboBox ItemsSource="{Binding RoomList}" SelectedItem="{Binding FocusClassDefaultPeRoom}"
                                          MinWidth="120" FontSize="11" Margin="0,0,8,4"
                                          Visibility="{Binding IsSingleClassWeekMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                          ToolTip="Зал или кабинет для физкультуры (если в другом здании)">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                        Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="{Binding Number}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding BuildingName}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <ListBox SelectedValue="{Binding WorkflowStep}" SelectedValuePath="Tag"
                                         BorderThickness="0" Background="Transparent" Margin="0,0,8,4">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="Margin" Value="0,0,4,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" Background="#F1F5F9" CornerRadius="6"
                                                                Padding="{TemplateBinding Padding}"
                                                                BorderBrush="#CBD5E1" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBoxItem Content="1 · Педагоги" Tag="Teachers"/>
                                    <ListBoxItem Content="2 · Предметы" Tag="Subjects"/>
                                    <ListBoxItem Content="3 · Кабинеты" Tag="Rooms"/>
                                </ListBox>

                                <Button Content="{Binding FullscreenToggleLabel}"
                                        Command="{Binding ToggleGridFullscreenCommand}"
                                        Style="{StaticResource SmallButtonStyle}" Margin="0,0,4,4"/>
                                <Button Content="Очистить расписание" Command="{Binding ClearScheduleCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,4"
                                        ToolTip="Снять все уроки: один класс / один день / вся неделя — по текущему режиму сетки"/>
                                <Button Content="Сброс масштаба" Command="{Binding ResetGridZoomCommand}"
                                        Style="{StaticResource SmallButtonStyle}" Margin="0,0,0,4"
                                        ToolTip="Ctrl + колёсико — масштаб сетки"/>
                            </WrapPanel>

                            <TextBlock Text="{Binding WorkflowStepHint}" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>

                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="8,4" Margin="0,4,0,0"
                                    Visibility="{Binding IsDragHintActive, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                <StackPanel>
                                    <TextBlock Text="Подсказки при перетаскивании" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <WrapPanel>
                                        <Border Background="#DCFCE7" BorderBrush="#16A34A" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                                            <TextBlock Text="🟢 удобно" FontSize="10"/>
                                        </Border>
                                        <Border Background="#FEF9C3" BorderBrush="#CA8A04" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                                            <TextBlock Text="🟡 нежелательно" FontSize="10"/>
                                        </Border>
                                        <Border Background="#FEE2E2" BorderBrush="#DC2626" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                                            <TextBlock Text="🔴 невозможно" FontSize="10"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,4,0,0"
                                       Visibility="{Binding IsSubjectsWorkflow, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                <TextBlock Text="Сивков:" FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox ItemsSource="{Binding ClassList}" SelectedItem="{Binding WorkloadChartClass}"
                                          MinWidth="72" FontSize="11" Margin="0,0,6,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button x:Name="WorkloadChartExpandButton"
                                        Content="{Binding WorkloadChartExpandLabel}"
                                        Command="{Binding ToggleWorkloadChartPopupCommand}"
                                        Style="{StaticResource SmallButtonStyle}" Margin="0,0,8,0"
                                        IsEnabled="{Binding HasWorkloadChartClass}"/>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#1E40AF" VerticalAlignment="Center">
                                    <Run Text="Неделя:"/>
                                    <Run Text="{Binding WorkloadChartWeekTotal, StringFormat={}{0:0.##}, Mode=OneWay}"/>
                                </TextBlock>
                            </WrapPanel>

                            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                    CornerRadius="6" Padding="8,4" Margin="0,6,0,0"
                                    Visibility="{Binding HasDayConflicts, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                <TextBlock Text="{Binding DayConflictSummary}" Foreground="#B91C1C"
                                           FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                            <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                    CornerRadius="6" Padding="8,4" Margin="0,4,0,0"
                                    Visibility="{Binding HasDayRoomSharedWarnings, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                <TextBlock Text="{Binding DayRoomSharedSummary}" Foreground="#92400E"
                                           FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Popup PlacementTarget="{Binding ElementName=WorkloadChartExpandButton}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade"
                           IsOpen="{Binding IsWorkloadChartPopupOpen, Mode=TwoWay}">
                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                CornerRadius="10" Padding="16" Margin="0,6,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="#0F172A"/>
                            </Border.Effect>
                            <StackPanel MinWidth="640">
                                <TextBlock Text="{Binding WorkloadChartCaption}" FontWeight="SemiBold"
                                           FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,10">
                                    <Run Text="Итого за неделю:"/>
                                    <Run Text="{Binding WorkloadChartWeekTotal, StringFormat={}{0:0.##}, Mode=OneWay}"/>
                                </TextBlock>
                                <controls:WeeklyLoadChartSurface Points="{Binding WeeklyLoadChartPointsLarge}"
                                                                   PolylinePoints="{Binding WeeklyLoadPolylinePointsLarge}"
                                                                   PlotWidth="620" PlotHeight="140" IsLarge="True"/>
                                <Button Content="Закрыть" HorizontalAlignment="Right" Margin="0,12,0,0"
                                        Command="{Binding ToggleWorkloadChartPopupCommand}"
                                        Style="{StaticResource SmallButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Grid MinHeight="200">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition MinWidth="0" MaxWidth="280"
                                              Width="{Binding IsGridFullscreen, Converter={x:Static conv:BoolToGridLengthConverter.Instance}, ConverterParameter=220|180}"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource DirectorySidePanelStyle}" VerticalAlignment="Stretch">
                            <DockPanel LastChildFill="True">
                                <ListBox DockPanel.Dock="Top" Margin="0,0,0,8"
                                         SelectedValue="{Binding WorkflowStep}" SelectedValuePath="Tag"
                                         BorderThickness="0" Background="Transparent"
                                         Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,4,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" Background="#F1F5F9" CornerRadius="6"
                                                                Padding="6,5" BorderBrush="#CBD5E1" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBoxItem Tag="Teachers" ToolTip="Педагоги">
                                        <TextBlock Text="👤" FontSize="15" HorizontalAlignment="Center"/>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Subjects" ToolTip="Предметы">
                                        <TextBlock Text="📗" FontSize="15" HorizontalAlignment="Center"/>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Rooms" ToolTip="Кабинеты">
                                        <TextBlock Text="🏫" FontSize="15" HorizontalAlignment="Center"/>
                                    </ListBoxItem>
                                </ListBox>
                                <TextBlock DockPanel.Dock="Top" Text="Палитра" FontWeight="SemiBold" Margin="0,0,0,8"
                                           Visibility="{Binding IsGridFullscreen, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}"/>
                                <ComboBox DockPanel.Dock="Top" Margin="0,0,0,8" FontSize="11"
                                          ItemsSource="{Binding SubjectPaletteClassFilters}"
                                          SelectedItem="{Binding SubjectPaletteClassFilter}"
                                          Visibility="{Binding ShowSubjectPaletteClassFilter, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                          ToolTip="Показать предметы выбранного класса или всех классов">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8"
                                            Visibility="{Binding IsTeachersWorkflow, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <Grid Margin="0,0,0,6">
                                        <TextBox Text="{Binding TeacherPaletteSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" Padding="6,4,24,4"
                                                 ToolTip="Поиск педагога по ФИО"/>
                                        <Button Width="20" Height="20" Padding="0" HorizontalAlignment="Right"
                                                Margin="0,0,2,0" VerticalAlignment="Center"
                                                Command="{Binding ClearTeacherPaletteSearchCommand}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                ToolTip="Очистить поиск"
                                                Visibility="{Binding TeacherPaletteSearchText, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                                            <TextBlock Text="✕" FontSize="10" Foreground="#64748B"/>
                                        </Button>
                                    </Grid>
                                    <UniformGrid Columns="4" Margin="0,0,0,2">
                                        <ToggleButton Margin="0,0,4,0" Padding="6,4"
                                                      IsChecked="{Binding TeacherPaletteFilterPrimary}"
                                                      ToolTip="Начальная школа">
                                            <TextBlock Text="①" FontSize="13" HorizontalAlignment="Center"/>
                                        </ToggleButton>
                                        <ToggleButton Margin="0,0,4,0" Padding="6,4"
                                                      IsChecked="{Binding TeacherPaletteFilterSubject}"
                                                      ToolTip="Предметники">
                                            <TextBlock Text="📗" FontSize="13" HorizontalAlignment="Center"/>
                                        </ToggleButton>
                                        <ToggleButton Margin="0,0,4,0" Padding="6,4"
                                                      IsChecked="{Binding TeacherPaletteFilterAuxiliary}"
                                                      ToolTip="Вспомогательный персонал">
                                            <TextBlock Text="🛠" FontSize="13" HorizontalAlignment="Center"/>
                                        </ToggleButton>
                                        <ToggleButton Padding="6,4"
                                                      IsChecked="{Binding TeacherPaletteFilterUnassigned}"
                                                      ToolTip="Без основного предмета">
                                            <TextBlock Text="？" FontSize="13" HorizontalAlignment="Center"/>
                                        </ToggleButton>
                                    </UniformGrid>
                                    <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"
                                               TextWrapping="Wrap">
                                        <Run Text="Выбран: "/>
                                        <Run Text="{Binding SelectedPlacementTeacherCaption, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <WrapPanel Margin="0,6,0,0">
                                        <Border Background="#DCFCE7" BorderBrush="#16A34A" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                                            <TextBlock Text="зелёный — разложен" FontSize="9"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                                <ListBox x:Name="TeacherPaletteList" ItemsSource="{Binding TeacherPaletteView}"
                                         SelectedItem="{Binding SelectedPlacementTeacher, Mode=TwoWay}"
                                         Style="{StaticResource ConstructorPaletteListStyle}"
                                         MinHeight="100"
                                         Visibility="{Binding IsTeachersWorkflow, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <ListBox.ItemContainerStyle>
