                                                ToolTip="Все классы · понедельник" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                                                Padding="4,2" MinHeight="0" MinWidth="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="2" Content="Вт" HorizontalAlignment="Stretch" Margin="1,0"
                                                Command="{Binding OpenAllClassesDayCommand}" CommandParameter="1"
                                                ToolTip="Все классы · вторник" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                                                Padding="4,2" MinHeight="0" MinWidth="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="3" Content="Ср" HorizontalAlignment="Stretch" Margin="1,0"
                                                Command="{Binding OpenAllClassesDayCommand}" CommandParameter="2"
                                                ToolTip="Все классы · среда" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                                                Padding="4,2" MinHeight="0" MinWidth="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="4" Content="Чт" HorizontalAlignment="Stretch" Margin="1,0"
                                                Command="{Binding OpenAllClassesDayCommand}" CommandParameter="3"
                                                ToolTip="Все классы · четверг" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                                                Padding="4,2" MinHeight="0" MinWidth="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="5" Content="Пт" HorizontalAlignment="Stretch" Margin="1,0"
                                                Command="{Binding OpenAllClassesDayCommand}" CommandParameter="4"
                                                ToolTip="Все классы · пятница" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                                                Padding="4,2" MinHeight="0" MinWidth="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="6" Content="Сб" HorizontalAlignment="Stretch" Margin="1,0"
                                                Command="{Binding OpenAllClassesDayCommand}" CommandParameter="5"
                                                ToolTip="Все классы · суббота" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                                                Padding="4,2" MinHeight="0" MinWidth="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding WeekGridRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="VerticalAlignment" Value="Top"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBreakColumn}" Value="True">
                                                                    <Setter Property="Margin" Value="0,0"/>
                                                                    <Setter Property="Height" Value="14"/>
                                                                    <Setter Property="MaxHeight" Value="14"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72"/>
                                                        <ColumnDefinition Width="588"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"
                                                            Background="#FFF7ED"
                                                            Visibility="{Binding IsBreakColumn, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                                        <TextBlock Text="{Binding LessonTitle}" FontSize="8" FontWeight="SemiBold"
                                                                   Foreground="#B45309"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"
                                                                Visibility="{Binding IsBreakColumn, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDynamicPauseColumn}" Value="True">
                                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding LessonTitle}" FontWeight="SemiBold" FontSize="11"/>
