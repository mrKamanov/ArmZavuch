                                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                                    <Setter Property="BorderBrush" Value="#16A34A"/>
                                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                                    <Setter Property="ToolTip">
                                                                                        <Setter.Value>
                                                                                            <ToolTip MaxWidth="360">
                                                                                                <TextBlock Text="{Binding DragHintMessage}" TextWrapping="Wrap"/>
                                                                                            </ToolTip>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DragHintLevel}" Value="{x:Static models:DragHintLevel.Caution}">
                                                                                    <Setter Property="Background" Value="#FEF9C3"/>
                                                                                    <Setter Property="BorderBrush" Value="#CA8A04"/>
                                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                                    <Setter Property="ToolTip">
                                                                                        <Setter.Value>
                                                                                            <ToolTip MaxWidth="360">
                                                                                                <TextBlock Text="{Binding DragHintMessage}" TextWrapping="Wrap"/>
                                                                                            </ToolTip>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DragHintLevel}" Value="{x:Static models:DragHintLevel.Blocked}">
                                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                                    <Setter Property="ToolTip">
                                                                                        <Setter.Value>
                                                                                            <ToolTip MaxWidth="360">
                                                                                                <TextBlock Text="{Binding DragHintMessage}" TextWrapping="Wrap"/>
                                                                                            </ToolTip>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                                                                    <Setter Property="BorderThickness" Value="2.5"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <ItemsControl ItemsSource="{Binding Parts}">
