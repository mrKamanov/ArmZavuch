                                                                    ToolTip="{Binding PlannedHoursToolTip}">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding PlannedHoursText}" FontWeight="Bold" FontSize="11"
                                                                               Foreground="{Binding PlannedHoursBrush, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                                    <TextBlock Text=" ч" FontSize="9" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Style="{StaticResource TeacherPaletteMetricBadgeStyle}" Margin="3,0,0,0"
                                                                    ToolTip="Уроков в сетке шаблона">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding ScheduledCountText}" FontWeight="Bold" FontSize="11"
                                                                               Foreground="{Binding ScheduledCountBrush, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                                    <TextBlock Text=" в сетке" FontSize="9" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </UniformGrid>
                                                        <TextBlock Grid.Row="4" Text="{Binding PlacementSelectionMarker}" FontSize="9"
                                                                   FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,4,0,0"
                                                                   Visibility="{Binding PlacementSelectionMarker, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                                        <TextBlock Grid.Row="5" Text="{Binding PlacementStatusText}" FontSize="9"
                                                                   FontWeight="SemiBold" Foreground="#15803D" Margin="0,6,0,0"
                                                                   Visibility="{Binding PlacementStatusText, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ListBox x:Name="SubjectPaletteList" ItemsSource="{Binding SubjectPaletteItems}"
                                         Style="{StaticResource ConstructorPaletteListStyle}"
                                         MinHeight="100"
                                         Visibility="{Binding IsSubjectsWorkflow, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border MouseLeftButtonDown="Palette_MouseLeftButtonDown"
                                                    MouseMove="SubjectPalette_MouseMove"
                                                    MouseLeftButtonUp="Palette_MouseLeftButtonUp">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource TeacherPaletteCardBorderStyle}">
                                                        <Setter Property="BorderBrush" Value="{Binding AccentBorderHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                        <Setter Property="Background" Value="{Binding AccentBackgroundHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                    </Style>
                                                </Border.Style>
                                                <Grid Style="{StaticResource PaletteAccentCardContentStyle}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5"/>
                                                        <ColumnDefinition Width="*" MinWidth="0"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Background="{Binding AccentBorderHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                    <Grid Grid.Column="1" Margin="10,8" MinWidth="0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" CornerRadius="4" Padding="5,1" HorizontalAlignment="Left" Margin="0,0,0,5"
                                                                BorderThickness="1"
                                                                BorderBrush="{Binding AccentBorderHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                                                Background="{Binding AccentBorderHex, Converter={x:Static conv:HexToLightBrushConverter.Instance}, ConverterParameter=0.18}">
                                                            <TextBlock Text="{Binding SubjectBadgeText}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="{Binding AccentBorderHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                        </Border>
                                                        <TextBlock Grid.Row="1" Text="{Binding PrimaryLine}" FontWeight="SemiBold" FontSize="11.5"
                                                                   Foreground="#0F172A" TextWrapping="Wrap" LineHeight="15" MaxHeight="32"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Row="2" Text="{Binding SecondaryLine}" FontSize="9.5"
                                                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0"
                                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ScrollViewer x:Name="RoomPaletteScroll" VerticalScrollBarVisibility="Auto" MinHeight="100"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding IsRoomsWorkflow, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
