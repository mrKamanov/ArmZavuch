                                                                   TextWrapping="Wrap" LineHeight="15" MaxHeight="32"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Row="2" Text="{Binding SecondaryLine}" FontSize="9.5"
                                                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0"
                                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                                   ToolTip="{Binding SecondaryLineToolTip}"
                                                                   Visibility="{Binding SecondaryLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
