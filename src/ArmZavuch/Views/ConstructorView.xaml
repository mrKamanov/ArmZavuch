                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      AllowDrop="True" DragOver="ScheduleGridHost_DragOver"
                                      ToolTip="Клик — выбрать ячейку; Ctrl+колёсико — масштаб; при перетаскивании — колёсико или край сетки для прокрутки">
                            <Border Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Border.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding GridZoom}" ScaleY="{Binding GridZoom}"/>
                                </Border.LayoutTransform>
                                <StackPanel>
                                <views:ConstructorDayGridView
                                    Visibility="{Binding IsAllClassesDayMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                    DataContext="{Binding}"/>
                                <views:ConstructorWeekGridView
                                    Visibility="{Binding IsAllClassesWeekMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                    DataContext="{Binding}"/>
                                <StackPanel Visibility="{Binding IsSingleClassWeekMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" FontSize="13"
                                               Visibility="{Binding FocusClass, Converter={x:Static conv:NullToCollapsedConverter.Instance}}">
                                        <Run Text="Неделя класса "/>
                                        <Run Text="{Binding FocusClass.DisplayName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="98"/>
                                            <ColumnDefinition Width="98"/>
                                            <ColumnDefinition Width="98"/>
                                            <ColumnDefinition Width="98"/>
                                            <ColumnDefinition Width="98"/>
                                            <ColumnDefinition Width="98"/>
