                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <ItemsControl ItemsSource="{Binding Rooms}" Margin="0,2,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                                                        CornerRadius="4" Padding="8,6" Margin="0,2" Cursor="Hand"
                                                                        MouseLeftButtonDown="Palette_MouseLeftButtonDown"
                                                                        MouseMove="RoomPalette_MouseMove"
                                                                        MouseLeftButtonUp="Palette_MouseLeftButtonUp">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding PrimaryLine}" FontWeight="SemiBold" FontSize="11"/>
                                                                        <TextBlock Text="{Binding SecondaryLine}" FontSize="10"
                                                                                   Foreground="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Expander>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                        <GridSplitter Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>
