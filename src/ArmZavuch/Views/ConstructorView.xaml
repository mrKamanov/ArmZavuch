                                                                                <DataTrigger Binding="{Binding IsBreakColumn}" Value="True">
                                                                                    <Setter Property="Background" Value="#FFF7ED"/>
                                                                                    <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                                                    <Setter Property="BorderThickness" Value="0.5"/>
                                                                                    <Setter Property="Height" Value="12"/>
                                                                                    <Setter Property="MinHeight" Value="12"/>
                                                                                    <Setter Property="MaxHeight" Value="12"/>
                                                                                    <Setter Property="Padding" Value="0"/>
                                                                                    <Setter Property="Margin" Value="2,0"/>
                                                                                    <Setter Property="AllowDrop" Value="False"/>
                                                                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                                                    <Setter Property="ToolTip" Value="{x:Null}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsDynamicPauseColumn}" Value="True">
                                                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                                                    <Setter Property="BorderBrush" Value="#86EFAC"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding HasConflict}" Value="True">
