<UserControl x:Class="ArmZavuch.Views.ConstructorWeekGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:views="clr-namespace:ArmZavuch.Views">
    <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="4">
        <StackPanel>
            <TextBlock Text="Сетка пуста — добавьте классы в справочниках и обновите конструктор."
                       FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                       Margin="8" HorizontalAlignment="Center"
                       Visibility="{Binding HasWeekDayPanels, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}"/>
            <ItemsControl ItemsSource="{Binding WeekDayPanels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,18">
                            <Border Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1"
                                    CornerRadius="6" Padding="10,6" Margin="0,6,0,10">
                                <TextBlock Text="{Binding DayTitle}" FontWeight="Bold" FontSize="14"
                                           Foreground="#1E40AF" HorizontalAlignment="Center"/>
                            </Border>
                            <views:ConstructorDayGridSectionsView
                                Sections="{Binding Sections}"
                                ViewModel="{Binding DataContext, RelativeSource={RelativeSource AncestorType=views:ConstructorWeekGridView}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
