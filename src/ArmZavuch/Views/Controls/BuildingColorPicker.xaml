<UserControl x:Class="ArmZavuch.Views.Controls.BuildingColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             ToolTip="Цвет здания на шахматке кабинетов и в мониторе диспетчерской">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="Цвет" Style="{StaticResource FormFieldLabelStyle}"
                   VerticalAlignment="Center" Margin="0,0,8,0"/>
        <Border Width="20" Height="20" CornerRadius="5"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                VerticalAlignment="Center">
            <Border Background="{Binding SelectedColorHex, RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={x:Static conv:HexToBrushConverter.Instance}}"
                    CornerRadius="4" Margin="1"/>
        </Border>
        <TextBlock Text="{Binding SelectedColorHex, RelativeSource={RelativeSource AncestorType=UserControl},
                                 Converter={x:Static conv:BuildingColorLabelConverter.Instance}}"
                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                   VerticalAlignment="Center" Margin="6,0,12,0"/>

        <ItemsControl ItemsSource="{Binding ColorChoices, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="0,0,4,0" Padding="0" Cursor="Hand"
                            Width="26" Height="26"
                            Command="{Binding PickColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Hex}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="ToolTip" Value="{Binding Label}"/>
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="False">
                                        <Setter Property="ToolTip" Value="{Binding Label, StringFormat={}{0} — уже занят другим зданием}"/>
                                        <Setter Property="Cursor" Value="No"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.IsEnabled>
                            <MultiBinding Converter="{x:Static conv:HexAvailabilityConverter.Instance}">
                                <Binding Path="Hex"/>
                                <Binding Path="BlockedColorHexes" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ring" Padding="2" CornerRadius="7"
                                        Background="Transparent" BorderThickness="2" BorderBrush="Transparent">
                                    <Border x:Name="swatch" CornerRadius="5"
                                            Background="{Binding Hex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                            BorderBrush="#FFFFFF" BorderThickness="1"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="swatch" Property="Opacity" Value="0.28"/>
                                        <Setter TargetName="ring" Property="Opacity" Value="0.55"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ring" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    </Trigger>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{x:Static conv:HexMatchConverter.Instance}">
                                                <Binding Path="Hex"/>
                                                <Binding Path="SelectedColorHex"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="ring" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="swatch" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
