<UserControl x:Class="ArmZavuch.Views.Controls.DayEditorGridCellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters">
    <Border x:Name="Root" Margin="1" Padding="5,4" CornerRadius="6"
            Width="152" MinWidth="152" MinHeight="96"
            BorderBrush="#E2E8F0" BorderThickness="1"
            AllowDrop="True" Cursor="Hand"
            MouseLeftButtonDown="Root_MouseLeftButtonDown"
            MouseMove="Root_MouseMove"
            MouseLeftButtonUp="Root_MouseLeftButtonUp"
            DragOver="Root_DragOver"
            DragLeave="Root_DragLeave"
            Drop="Root_Drop">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="ToolTip">
                    <Setter.Value>
                        <ToolTip MaxWidth="360">
                            <TextBlock Text="{Binding ToolTip}" TextWrapping="Wrap"/>
                        </ToolTip>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="#EFF6FF"/>
                        <Setter Property="BorderBrush" Value="#2563EB"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ColumnKind}" Value="Window">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ColumnKind}" Value="Empty">
                        <Setter Property="Background" Value="#FCFCFD"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ColumnKind}" Value="DynamicPause">
                        <Setter Property="Background" Value="#F0FDF4"/>
                        <Setter Property="BorderBrush" Value="#BBF7D0"/>
                        <Setter Property="Cursor" Value="Arrow"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ColumnKind}" Value="Break">
                        <Setter Property="Background" Value="#FFFBEB"/>
                        <Setter Property="BorderBrush" Value="#FDE68A"/>
                        <Setter Property="Cursor" Value="Arrow"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                            <Condition Binding="{Binding IsSelected}" Value="False"/>
                            <Condition Binding="{Binding ColumnKind}" Value="Empty"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#F5F3FF"/>
                        <Setter Property="BorderBrush" Value="#DDD6FE"/>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                            <Condition Binding="{Binding IsSelected}" Value="False"/>
                            <Condition Binding="{Binding HasLesson}" Value="True"/>
                            <Condition Binding="{Binding HasConflict}" Value="False"/>
                            <Condition Binding="{Binding StatusKind}" Value="Normal"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#FAF5FF"/>
                        <Setter Property="BorderBrush" Value="#DDD6FE"/>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                            <Condition Binding="{Binding ColumnKind}" Value="Break"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="#C4B5FD"/>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                            <Condition Binding="{Binding ColumnKind}" Value="DynamicPause"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="#C4B5FD"/>
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding StatusKind}" Value="Pending">
                        <Setter Property="Background" Value="#FEF2F2"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusKind}" Value="Replacement">
                        <Setter Property="Background" Value="#F0FDF4"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusKind}" Value="Transition">
                        <Setter Property="Background" Value="#FFF7ED"/>
                        <Setter Property="BorderBrush" Value="#FB923C"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding HasRoomSharedWarning}" Value="True"/>
                            <Condition Binding="{Binding HasConflict}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#FFFBEB"/>
                        <Setter Property="BorderBrush" Value="#F59E0B"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip MaxWidth="360">
                                    <TextBlock Text="{Binding RoomSharedHint}" TextWrapping="Wrap"/>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding HasConflict}" Value="True">
                        <Setter Property="Background" Value="#FEF2F2"/>
                        <Setter Property="BorderBrush" Value="#DC2626"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip MaxWidth="360">
                                    <StackPanel>
                                        <TextBlock Text="Конфликт" FontWeight="SemiBold" Foreground="#B91C1C"/>
                                        <TextBlock Text="{Binding ConflictHint}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding ToolTip}" TextWrapping="Wrap" Margin="0,6,0,0"
                                                   Foreground="#64748B" FontSize="11"
                                                   Visibility="{Binding ToolTip, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                    </StackPanel>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" CornerRadius="4,0,0,4"
                    Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                    Visibility="{Binding HasLesson, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
            <StackPanel Grid.Column="1" Margin="4,3,3,3">
                <TextBlock x:Name="PrimaryLine" Text="{Binding PrimaryLine}"
                           FontSize="12" FontWeight="SemiBold" LineHeight="14"
                           Foreground="#0F172A" TextWrapping="Wrap"/>
                <TextBlock x:Name="SecondaryLine" Text="{Binding SecondaryLine}"
                           FontSize="11" LineHeight="13" Foreground="#64748B"
                           TextWrapping="Wrap" Margin="0,2,0,0"
                           Visibility="{Binding SecondaryLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                <TextBlock x:Name="StatusLine" Text="{Binding StatusLine}"
                           FontSize="10" FontWeight="SemiBold" LineHeight="13"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,4,0,0"
                           Visibility="{Binding StatusLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
