<UserControl x:Class="ArmZavuch.Views.Controls.DayEditorGridRowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:controls="clr-namespace:ArmZavuch.Views.Controls">
    <Grid Margin="0,0,0,3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="148" MinWidth="148"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border x:Name="ClassHeader" Grid.Column="0" BorderBrush="#E2E8F0"
                BorderThickness="1" CornerRadius="6" Padding="0" Margin="0,0,2,0"
                Cursor="Hand" Background="#F1F5F9"
                MouseLeftButtonDown="ClassHeader_MouseLeftButtonDown">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="#DBEAFE"/>
                            <Setter Property="BorderBrush" Value="#2563EB"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="4" CornerRadius="6,0,0,6"
                        Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                        Visibility="{Binding BuildingColorHex, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                <StackPanel Grid.Column="1" Margin="8,6,8,6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="11"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                    <TextBlock Text="{Binding SubLabel}" FontSize="9" Foreground="#64748B"
                               TextWrapping="Wrap"
                               Visibility="{Binding SubLabel, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                </StackPanel>
            </Grid>
        </Border>
        <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:DayEditorGridCellView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
