<UserControl x:Class="ArmZavuch.Views.Controls.DayEditorStepperRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,0,0,6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="DayEditorLabel"/>
            <ColumnDefinition Width="Auto" SharedSizeGroup="DayEditorStepper"/>
            <ColumnDefinition Width="Auto" SharedSizeGroup="DayEditorUnit"/>
            <ColumnDefinition Width="*" MinWidth="96" SharedSizeGroup="DayEditorApply"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource DayEditorRowLabelStyle}"/>
        <Border Grid.Column="1" Style="{StaticResource NumericStepperShellStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="−" Style="{StaticResource NumericStepperButtonStyle}"
                        Command="{Binding DecreaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        ToolTip="{Binding DecreaseToolTip, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1,0,1,0" MinWidth="36">
                    <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Style="{StaticResource NumericStepperValueTextStyle}"/>
                </Border>
                <Button Grid.Column="2" Content="+" Style="{StaticResource NumericStepperButtonStyle}"
                        Command="{Binding IncreaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        ToolTip="{Binding IncreaseToolTip, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>
        </Border>
        <TextBlock Grid.Column="2" Text="{Binding Unit, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource NumericStepperUnitTextStyle}"/>
        <Button Grid.Column="3" Style="{StaticResource DayEditorApplyButtonStyle}"
                Command="{Binding ApplyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Content="{Binding ApplyLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>
</UserControl>
