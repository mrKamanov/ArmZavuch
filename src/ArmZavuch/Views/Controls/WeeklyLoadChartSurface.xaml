<UserControl x:Class="ArmZavuch.Views.Controls.WeeklyLoadChartSurface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             x:Name="Root">
    <UserControl.Resources>
        <Style x:Key="ValueLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E40AF"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLarge, ElementName=Root}" Value="True">
                    <Setter Property="FontSize" Value="12"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DayLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLarge, ElementName=Root}" Value="True">
                    <Setter Property="FontSize" Value="11"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6"
                Width="{Binding PlotWidth, ElementName=Root}" Height="{Binding PlotCanvasHeight, ElementName=Root}"
                ClipToBounds="False" Padding="2,4,2,2">
            <Canvas Width="{Binding PlotWidth, ElementName=Root}" Height="{Binding PlotAreaHeight, ElementName=Root}"
                    ClipToBounds="False" VerticalAlignment="Top">
                <Line X1="14" Y1="{Binding PlotAreaBottom, ElementName=Root}" X2="{Binding PlotLineRight, ElementName=Root}"
                      Y2="{Binding PlotAreaBottom, ElementName=Root}" Stroke="#E2E8F0" StrokeThickness="1"/>
                <Line X1="14" Y1="{Binding PlotAreaMidHigh, ElementName=Root}" X2="{Binding PlotLineRight, ElementName=Root}"
                      Y2="{Binding PlotAreaMidHigh, ElementName=Root}" Stroke="#F1F5F9" StrokeThickness="1"/>
                <Line X1="14" Y1="{Binding PlotAreaMidLow, ElementName=Root}" X2="{Binding PlotLineRight, ElementName=Root}"
                      Y2="{Binding PlotAreaMidLow, ElementName=Root}" Stroke="#F1F5F9" StrokeThickness="1"/>
                <Polyline Points="{Binding PolylinePoints, ElementName=Root, Converter={x:Static conv:StringToPointCollectionConverter.Instance}}"
                          Stroke="#2563EB" StrokeThickness="{Binding LineThickness, ElementName=Root}"
                          StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                          Fill="Transparent"/>
                <ItemsControl ItemsSource="{Binding Points, ElementName=Root}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding ValueLabelX}"/>
                            <Setter Property="Canvas.Top" Value="{Binding ValueLabelY}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ScoreLabel}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ValueLabelStyle}">
                                        <Setter Property="Width" Value="40"/>
                                        <Setter Property="Margin" Value="-20,0,0,0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValueLabelBelow}" Value="True">
                                                <Setter Property="Margin" Value="-20,-2,0,0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Points, ElementName=Root}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding ChartX}"/>
                            <Setter Property="Canvas.Top" Value="{Binding ChartY}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="{Binding DotSize, ElementName=Root}" Height="{Binding DotSize, ElementName=Root}"
                                     Margin="{Binding DotMargin, ElementName=Root}"
                                     Stroke="White" StrokeThickness="1.5">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#60A5FA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPeakDay}" Value="True">
                                                <Setter Property="Fill" Value="#2563EB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Border>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Points, ElementName=Root}"
                      Margin="0,4,0,0" Width="{Binding PlotWidth, ElementName=Root}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Height="30"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding ChartX}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="{Binding DayLabelWidth, ElementName=Root}"
                                Margin="{Binding DayLabelMargin, ElementName=Root}">
                        <TextBlock Text="{Binding DayName}" Style="{StaticResource DayLabelStyle}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
