<Window x:Class="ArmZavuch.Views.Dialogs.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="420"
        SizeToContent="Height"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24,20,24,24"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.18" Color="#0F172A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="HeaderPanel" Grid.Row="0"
                  Background="Transparent" Cursor="SizeAll"
                  MouseLeftButtonDown="HeaderPanel_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBorder" Grid.Column="0"
                        Width="44" Height="44" CornerRadius="22" Margin="0,0,14,0">
                    <TextBlock x:Name="IconText" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="TitleText" Grid.Column="1"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Button x:Name="CloseButton" Grid.Column="2"
                        Content="✕" Width="28" Height="28" Padding="0"
                        VerticalAlignment="Top"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Закрыть"
                        Click="CloseButton_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="1" MaxHeight="280" Margin="0,14,0,0"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="13" LineHeight="20"/>
            </ScrollViewer>

            <StackPanel x:Name="InputPanel" Grid.Row="2" Margin="0,14,0,0" Visibility="Collapsed">
                <TextBlock x:Name="InputLabelText" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="InputTextBox" FontSize="13" Padding="8,6"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
            </StackPanel>

            <StackPanel x:Name="ButtonsPanel" Grid.Row="3"
                        Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,22,0,0"/>
        </Grid>
    </Border>
</Window>
