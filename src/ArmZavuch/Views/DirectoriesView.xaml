                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}"
                                                                  Style="{StaticResource TeacherClassChipCheckBoxStyle}"
                                                                  Margin="0,0,8,8"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource TeacherCardSectionStyle}">
                                        <StackPanel>
                                            <ContentControl Content="Нагрузка из справочника"
                                                            ContentTemplate="{StaticResource TeacherCardSectionHeaderTemplate}"/>
                                            <TextBlock Text="Отметьте строки учебного плана, которые ведёт педагог. Сначала — ваши предметы в отмеченных классах, затем те же предметы в других классах, потом прочая нагрузка классов и остальное. Зелёный — свободно; голубой — подгруппы, можно второго педагога; жёлтый — место занято."
                                                       Style="{StaticResource SidePanelHelpTextStyle}" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding CurriculumAssignmentEmptyHint}" FontSize="10"
                                                       Foreground="#B45309" TextWrapping="Wrap" Margin="0,2,0,8"
                                                       Visibility="{Binding CurriculumAssignmentEmptyHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                            <TextBlock Text="{Binding TeacherCurriculumTotalDisplay}" FontWeight="SemiBold"
                                                       FontSize="12" Foreground="#1E40AF" Margin="0,0,0,8"
                                                       Visibility="{Binding TeacherCurriculumTotalDisplay, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
