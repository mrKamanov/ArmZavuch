                                                <ComboBoxItem Content="Предметник" Tag="Subject"/>
                                                <ComboBoxItem Content="Начальные классы" Tag="Primary"/>
                                                <ComboBoxItem Content="Вспомогательный" Tag="Auxiliary"/>
                                            </ComboBox>
                                            <TextBlock Text="Должность" Style="{StaticResource FormFieldLabelStyle}"/>
