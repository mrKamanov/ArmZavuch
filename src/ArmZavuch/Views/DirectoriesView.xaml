                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,10">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11"
                                                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"
                                                                       Visibility="{Binding Title, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                                            <ItemsControl ItemsSource="{Binding Items}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="4" Padding="4,2" Margin="0,0,0,4">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                                    <Setter Property="ToolTip" Value="{Binding AssignmentHint}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsUnassignedHighlight}" Value="True">
                                                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsSubgroupSharedHighlight}" Value="True">
                                                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsOthersHighlight}" Value="True">
                                                                                            <Setter Property="Background" Value="#FFFBEB"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                                                      IsEnabled="{Binding IsAssignmentEnabled}">
                                                                                <StackPanel>
                                                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                                                    <TextBlock Text="{Binding DetailsLine}" FontSize="10"
                                                                                               Foreground="{StaticResource MutedTextBrush}"/>
                                                                                </StackPanel>
                                                                            </CheckBox>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

