                            <DataGridTextColumn Header="Смена" Binding="{Binding ShiftDisplay}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CurriculumLoadNumericTextStyle}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Звонки" Binding="{Binding BellTemplateDisplay}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CurriculumLoadMutedTextStyle}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Учеников" Binding="{Binding StudentCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CurriculumLoadNumericTextStyle}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="68" CellTemplate="{StaticResource DataGridRowActionsTemplate}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Border>
                </DockPanel>
            </TabItem>
            <TabItem Header="Сотрудники">
                <Grid Margin="12,8,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1.1*" MinWidth="220" MaxWidth="480"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}">
                            <WrapPanel Style="{StaticResource CrudFormWrapStyle}">
                                <TextBox MinWidth="120" Width="180" Text="{Binding NewTeacherName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="ФИО" Margin="0,0,8,4"
                                         helpers:DuplicateHighlight.IsDuplicate="{Binding IsNewTeacherDuplicate}"/>
                                <ComboBox MinWidth="100" Width="130" SelectedValue="{Binding NewTeacherType}" Margin="0,0,8,4"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="Предметник" Tag="Subject"/>
                                    <ComboBoxItem Content="Начальные" Tag="Primary"/>
                                    <ComboBoxItem Content="Вспомогательный" Tag="Auxiliary"/>
                                </ComboBox>
                                <Button Content="Добавить" Command="{Binding AddTeacherCommand}" Margin="0,0,8,4"/>
                            </WrapPanel>
                        </Border>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="{Binding NewTeacherDuplicateHint}" FontSize="10" Foreground="#DC2626"
                                       Visibility="{Binding NewTeacherDuplicateHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding NewTeacherSuggestionHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                                <TextBlock Text="{Binding NewTeacherSuggestionHint}" FontSize="10" Foreground="#B45309" TextWrapping="Wrap"/>
                                <Button Content="Применить" Style="{StaticResource SmallButtonStyle}" Margin="8,0,0,0"
                                        Command="{Binding ApplyNewTeacherSuggestionCommand}"/>
                            </StackPanel>
                        </StackPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBox Text="{Binding TeacherFilterText, UpdateSourceTrigger=PropertyChanged}"
