<UserControl x:Class="ArmZavuch.Views.DirectoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:helpers="clr-namespace:ArmZavuch.Views.Helpers"
             xmlns:controls="clr-namespace:ArmZavuch.Views.Controls"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <UserControl.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoLastCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClearCheckboxSelectionCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource ModuleHeaderBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Справочники" Style="{StaticResource ModulePageTitleStyle}"/>
                    <TextBlock Text="{Binding SelectionHint}" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource ToolbarButtonGroupStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                Command="{Binding UndoLastCommand}"
                                IsEnabled="{Binding CanUndo}"
                                ToolTip="Отменить последнее действие (Ctrl+Z)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↩" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Отменить" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                        <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                Command="{Binding LoadCommand}"
                                ToolTip="Обновить данные из базы">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Обновить" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,8,0,0"
                   Foreground="{StaticResource MutedTextBrush}"/>

        <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveTabIndex}"
                    Style="{StaticResource ModuleTabControlStyle}"
                    VerticalAlignment="Stretch">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModuleTabItemStyle}"/>
            </TabControl.Resources>
            <TabItem Header="Здания">
                <controls:ScrollableTabContent Padding="12,8,12,16">
                    <StackPanel>
                        <Border Style="{StaticResource CrudFormPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="Здание" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="180"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Название" Style="{StaticResource FormFieldLabelStyle}"/>
                                        <TextBox Text="{Binding NewBuildingName, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Название здания"
                                                 helpers:DuplicateHighlight.IsDuplicate="{Binding IsNewBuildingDuplicate}"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                        <Button Content="{Binding SaveBuildingLabel}" Command="{Binding SaveBuildingCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Удалить" Command="{Binding DeleteBuildingCommand}" Margin="0,0,8,0"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                        <Button Content="Отмена" Command="{Binding CancelEditCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </WrapPanel>
                                </Grid>

                                <controls:BuildingColorPicker Margin="0,10,0,0"
                                    SelectedColorHex="{Binding NewBuildingColor, UpdateSourceTrigger=PropertyChanged}"
                                    ColorChoices="{Binding BuildingColorChoices}"
                                    BlockedColorHexes="{Binding BlockedBuildingColorHexes}"
                                    PickColorCommand="{Binding SelectBuildingColorCommand}"/>

                                <TextBlock Text="{Binding NewBuildingDuplicateHint}" FontSize="10" Foreground="#DC2626"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding NewBuildingDuplicateHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                            Visibility="{Binding NewBuildingSuggestionHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                                    <TextBlock Text="{Binding NewBuildingSuggestionHint}" FontSize="10" Foreground="#B45309"/>
                                    <Button Content="Применить" Style="{StaticResource SmallButtonStyle}" Margin="8,0,0,0"
                                            Command="{Binding ApplyNewBuildingSuggestionCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CrudFormPanelStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Переходы между зданиями" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding BuildingRoutesHint}" FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Border Style="{StaticResource DirectoriesTableCardStyle}" Margin="0"
                                        Visibility="{Binding CanEditBuildingRoutes, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <DataGrid ItemsSource="{Binding BuildingRouteMatrix}" AutoGenerateColumns="False"
                                              Style="{StaticResource BuildingRouteDataGridStyle}"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                              MaxHeight="220" Margin="0">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Маршрут" Width="*" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ContentControl Content="{Binding}"
                                                                        ContentTemplate="{StaticResource BuildingRoutePathCellTemplate}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Минут" Width="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ContentControl Content="{Binding}"
                                                                        ContentTemplate="{StaticResource BuildingRouteMinutesEditorTemplate}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                            Visibility="{Binding CanEditBuildingRoutes, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                    <Button Content="Сохранить переходы" Command="{Binding SaveBuildingRoutesCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left"/>
                                    <Button Content="Всем 40 мин" Command="{Binding ApplyDefaultBuildingRoutesCommand}"
                                            Style="{StaticResource SmallButtonStyle}" Margin="8,0,0,0"
                                            ToolTip="Подставить 40 минут во все пары — затем сохраните"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Список зданий" FontWeight="SemiBold" Margin="0,12,0,6"/>
                        <Border Style="{StaticResource DirectoriesTableCardStyle}" Margin="0">
                        <DataGrid ItemsSource="{Binding BuildingList}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Style="{StaticResource CrudDataGridStyle}"
                                  MinHeight="140"
                                  Margin="0"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectedItem="{Binding SelectedBuilding}"
                                  helpers:DataGridCrudBehaviors.EditRowCommand="{Binding EditBuildingRowCommand}"
                                  helpers:DataGridCrudBehaviors.DeleteRowCommand="{Binding DeleteBuildingRowCommand}">
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteBuildingCommand}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="40"
                                                        HeaderTemplate="{StaticResource DataGridCheckboxHeaderTemplate}"
                                                        CellTemplate="{StaticResource DataGridCheckboxCellTemplate}"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CurriculumLoadSubjectTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Цвет" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                        Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                <TextBlock Text="{Binding ColorHex, Converter={x:Static conv:BuildingColorLabelConverter.Instance}}"
                                                           FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="68" CellTemplate="{StaticResource DataGridRowActionsTemplate}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                    </StackPanel>
                </controls:ScrollableTabContent>
            </TabItem>
            <TabItem Header="Предметы">
                <Grid Margin="12,8,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="240"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="280" MinWidth="200"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="Ваш справочник" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding SubjectDirectoryHint}"
                                               Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                                </Border>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Название предмета" Style="{StaticResource FormFieldLabelStyle}"/>
                                        <TextBox Text="{Binding NewSubjectName, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Как предмет называется в расписании и учебном плане (например, «Математика»)"
                                                 helpers:DuplicateHighlight.IsDuplicate="{Binding IsNewSubjectDuplicate}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Width="72" Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource FormFieldLabelStyle}">
                                            <TextBlock.ToolTip>
                                                <TextBlock Text="{Binding SubjectDifficultyFieldHint}" TextWrapping="Wrap" MaxWidth="320"/>
                                            </TextBlock.ToolTip>
                                            <Run Text="Балл Сивкова"/>
                                        </TextBlock>
                                        <TextBox Text="{Binding NewSubjectDifficulty}" Width="72"
                                                 ToolTip="{Binding SubjectDifficultyFieldHint}"/>
                                        <TextBlock Text="{Binding NewSubjectDifficultyHint}" FontSize="10" Foreground="#B45309"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"
                                                   Visibility="{Binding NewSubjectDifficultyHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <Button Content="{Binding SaveSubjectLabel}" Command="{Binding SaveSubjectCommand}" Margin="0,0,8,4"/>
                                        <Button Content="Удалить" Command="{Binding DeleteSubjectCommand}" Margin="0,0,8,4"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                        <Button Content="Отмена" Command="{Binding CancelEditCommand}" Margin="0,0,0,4"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </WrapPanel>
                                </Grid>
                                <TextBlock Text="{Binding SubjectDifficultyFieldHint}" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding NewSubjectDuplicateHint}" FontSize="10" Foreground="#DC2626" Margin="0,0,0,4"
                                           Visibility="{Binding NewSubjectDuplicateHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                            Visibility="{Binding NewSubjectSuggestionHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                                    <TextBlock Text="{Binding NewSubjectSuggestionHint}" FontSize="10" Foreground="#B45309"/>
                                    <Button Content="Применить" Style="{StaticResource SmallButtonStyle}" Margin="8,0,0,0"
                                            Command="{Binding ApplyNewSubjectSuggestionCommand}"/>
                                </StackPanel>
                                <TextBlock Text="Поиск в справочнике" Style="{StaticResource FormFieldLabelStyle}"/>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                                             Text="{Binding SubjectFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Фильтр по названию — таблица ниже покажет только подходящие строки"/>
                                    <Button Grid.Column="1" Content="Обновить баллы"
                                            Command="{Binding RefreshSubjectDifficultiesCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            ToolTip="Пересчитать баллы Сивкова по вариантам расписаний Минпросвещения. Отмеченные галочкой — только они; иначе все предметы."/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DirectoriesTableCardStyle}" Margin="0,8,0,0">
                        <DataGrid ItemsSource="{Binding FilteredSubjectList}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Style="{StaticResource CrudDataGridStyle}"
                                  Margin="0"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectedItem="{Binding SelectedSubject}"
                                  helpers:DataGridCrudBehaviors.EditRowCommand="{Binding EditSubjectRowCommand}"
                                  helpers:DataGridCrudBehaviors.DeleteRowCommand="{Binding DeleteSubjectRowCommand}"
                                  ToolTip="Дважды щёлкните строку для редактирования. ✓ — отметить для удаления нескольких предметов сразу.">
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteSubjectCommand}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="40"
                                                        HeaderTemplate="{StaticResource DataGridCheckboxHeaderTemplate}"
                                                        CellTemplate="{StaticResource DataGridCheckboxCellTemplate}"/>
                                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="Предмет"
                                                   ToolTip="Название предмета — должно совпадать с учебным планом и ячейками в конструкторе"/>
                                    </DataGridTextColumn.Header>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CurriculumLoadSubjectTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding DifficultyCatalogRange}" Width="88">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="Сивков"
                                                   ToolTip="Балл трудности по параллелям (шаблон Минпросвещения): 8–13 для математики и т.д. В расписании берётся значение для параллели класса"/>
                                    </DataGridTextColumn.Header>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CurriculumLoadNumericTextStyle}">
                                            <Setter Property="ToolTip" Value="{Binding DifficultyScore, StringFormat=Ориентир в справочнике: {0}}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="68" CellTemplate="{StaticResource DataGridRowActionsTemplate}">
                                    <DataGridTemplateColumn.Header>
                                        <TextBlock Text="⋯" HorizontalAlignment="Center"
                                                   ToolTip="Изменить или удалить одну строку"/>
                                    </DataGridTemplateColumn.Header>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                    </DockPanel>
                    <GridSplitter Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>
                    <Border Grid.Column="2" Style="{StaticResource DirectorySidePanelStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Типовой перечень (ФГОС РФ)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding SubjectCatalogHint}"
                                               Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                                </Border>
                                <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding SubjectCatalogBadgesHint}"
                                               Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                                </Border>
                                <TextBlock Text="Параллель" Style="{StaticResource FormFieldLabelStyle}"/>
                                <ComboBox Width="120" Margin="0,0,0,8"
                                          ItemsSource="{Binding CatalogGradeLabels}"
                                          SelectedIndex="{Binding CatalogGradeIndex}"
                                          ToolTip="Показать предметы, предусмотренные для выбранного класса"/>
                                <TextBlock Text="Поиск в перечне" Style="{StaticResource FormFieldLabelStyle}"/>
                                <TextBox Margin="0,0,0,8"
                                         Text="{Binding CatalogSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Отфильтровать список по части названия"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="Добавить выбранный" Command="{Binding ImportCatalogEntryCommand}" Margin="0,0,8,0"
                                            ToolTip="Скопировать выделенную строку в ваш справочник слева"/>
                                    <Button Content="Все для класса" Command="{Binding ImportCatalogForGradeCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            ToolTip="Добавить все предметы выбранной параллели (уже существующие по названию пропускаются)"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource DirectoriesTableCardStyle}" Margin="0">
                            <ListBox ItemsSource="{Binding CatalogEntries}"
                                     Style="{StaticResource DirectoryCatalogListBoxStyle}"
                                     SelectedItem="{Binding SelectedCatalogEntry}"
                                     ToolTip="Выберите строку и нажмите «Добавить выбранный»"/>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Классы">
                <DockPanel Margin="12,8,12,0">
                    <Border DockPanel.Dock="Top" Style="{StaticResource CrudFormPanelStyle}">
                        <StackPanel>
                        <WrapPanel Style="{StaticResource CrudFormWrapStyle}">
                            <StackPanel Width="52" Margin="0,0,8,4">
                                <TextBlock Text="Параллель" Style="{StaticResource FormFieldLabelStyle}"/>
                                <TextBox Text="{Binding NewClassGrade, UpdateSourceTrigger=PropertyChanged}" ToolTip="1–11"
                                         helpers:DuplicateHighlight.IsDuplicate="{Binding IsNewClassDuplicate}"/>
                            </StackPanel>
                            <StackPanel Width="52" Margin="0,0,8,4">
                                <TextBlock Text="Буква" Style="{StaticResource FormFieldLabelStyle}"/>
                                <TextBox Text="{Binding NewClassLetter, UpdateSourceTrigger=PropertyChanged}" ToolTip="А, Б, В…"
                                         helpers:DuplicateHighlight.IsDuplicate="{Binding IsNewClassDuplicate}"/>
                            </StackPanel>
                            <StackPanel Width="80" Margin="0,0,8,4">
                                <TextBlock Text="Смена" Style="{StaticResource FormFieldLabelStyle}"/>
                                <ComboBox IsEditable="True"
                                          Text="{Binding NewClassShift, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="1 или 2. СП 2.4.3648-20 п. 3.4.15: 1, 5, 9–11 и коррекционные — только 1-я смена">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Width="64" Margin="0,0,8,4">
                                <TextBlock Text="Учеников" Style="{StaticResource FormFieldLabelStyle}"/>
                                <TextBox Text="{Binding NewClassStudentCount, UpdateSourceTrigger=PropertyChanged}" ToolTip="Число обучающихся"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,4">
                                <TextBlock Text="Тип" Style="{StaticResource FormFieldLabelStyle}"/>
                                <CheckBox Content="Коррекционный" IsChecked="{Binding NewClassIsCorrectional}" Margin="0,2,0,0"
                                          ToolTip="Компенсирующий класс для обучающихся с ОВЗ — по СанПиН только 1-я смена"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,4" MinWidth="200">
                                <TextBlock Text="Здание" Style="{StaticResource FormFieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding BuildingList}" SelectedItem="{Binding NewClassBuilding}"
                                          ToolTip="Корпус, где учится класс — столбцы в конструкторе группируются по зданиям">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                        Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,4" MinWidth="220">
                                <TextBlock Text="Кабинет класса" Style="{StaticResource FormFieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding RoomList}" SelectedItem="{Binding NewClassDefaultRoom}"
                                              ToolTip="Обычно свой кабинет — подставится в конструкторе; здание для сетки задаётся отдельно">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                            Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                    <TextBlock VerticalAlignment="Center">
                                                        <Run Text="{Binding Number}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding BuildingName}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Grid.Column="1" Content="Снять"
                                            Command="{Binding ClearNewClassDefaultRoomCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="6,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding NewClassDefaultRoom, Converter={x:Static conv:NullToCollapsedConverter.Instance}}"
                                            ToolTip="Не закреплять кабинет за классом"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,4" MinWidth="220">
                                <TextBlock Text="Физкультура" Style="{StaticResource FormFieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding RoomList}" SelectedItem="{Binding NewClassDefaultPeRoom}"
                                              ToolTip="Зал или кабинет для физ-ры — если класс ходит в другое здание или в свой зал">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Style="{StaticResource BuildingListColorChipStyle}"
                                                            Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                                    <TextBlock VerticalAlignment="Center">
                                                        <Run Text="{Binding Number}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding BuildingName}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Grid.Column="1" Content="Снять"
                                            Command="{Binding ClearNewClassDefaultPeRoomCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="6,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding NewClassDefaultPeRoom, Converter={x:Static conv:NullToCollapsedConverter.Instance}}"
                                            ToolTip="Не назначать спортзал по умолчанию"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,4" MinWidth="220">
                                <TextBlock Text="Звонки" Style="{StaticResource FormFieldLabelStyle}"/>
                                <ComboBox IsEditable="True" ItemsSource="{Binding BellTemplateNames}"
                                          Text="{Binding NewClassBellTemplate, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Пусто — по умолчанию (1 класс / 1 или 2 смена). Иначе — свой шаблон, класс будет в отдельной группе сетки"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,18,0,4">
                                <Button Content="{Binding SaveClassLabel}" Command="{Binding SaveClassCommand}" Margin="0,0,8,0"/>
