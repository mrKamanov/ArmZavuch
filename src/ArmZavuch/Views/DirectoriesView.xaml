                                                     Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="Ссылка (мессенджер, почта…)" Style="{StaticResource FormFieldLabelStyle}"/>
                                            <TextBox Style="{StaticResource SidePanelFieldStyle}"
                                                     Text="{Binding EditContactUrl, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="Заметка к контакту" Style="{StaticResource FormFieldLabelStyle}"/>
                                            <TextBox Style="{StaticResource SidePanelFieldStyle}" Margin="0,2,0,0"
                                                     Text="{Binding EditContactNote, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource TeacherCardSectionStyle}">
                                        <StackPanel>
                                            <ContentControl Content="Подсказки для расписания"
                                                            ContentTemplate="{StaticResource TeacherCardSectionHeaderTemplate}"/>
