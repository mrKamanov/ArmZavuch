                                                        <ComboBoxItem Content="Вт"/>
                                                        <ComboBoxItem Content="Ср"/>
                                                        <ComboBoxItem Content="Чт"/>
                                                        <ComboBoxItem Content="Пт"/>
                                                        <ComboBoxItem Content="Сб"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="Здание:" Style="{StaticResource SidePanelInlineLabelStyle}" Margin="0,0,6,0"/>
                                                    <ComboBox Width="160" MinWidth="120"
                                                              ItemsSource="{Binding BuildingList}"
                                                              DisplayMemberPath="Name"
                                                              SelectedItem="{Binding NewTeacherBuildingDayBuilding}"/>
