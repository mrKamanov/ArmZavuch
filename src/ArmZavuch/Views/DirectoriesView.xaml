                                    Visibility="{Binding TeacherFilterText, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                        </Grid>
                        <Border Style="{StaticResource DirectoriesTableCardStyle}" Margin="0,4,0,0" Padding="4,6,2,6">
                        <ListBox ItemsSource="{Binding FilteredTeacherList}"
                                 Style="{StaticResource TeacherPickerListBoxStyle}"
                                 ItemTemplate="{StaticResource TeacherPickerListItemTemplate}"
                                 SelectedItem="{Binding SelectedTeacher}"
                                 helpers:DataGridCrudBehaviors.EditRowCommand="{Binding EditTeacherRowCommand}"
                                 helpers:DataGridCrudBehaviors.DeleteRowCommand="{Binding DeleteTeacherRowCommand}">
                            <ListBox.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteTeacherCommand}"/>
                            </ListBox.InputBindings>
                        </ListBox>
                        </Border>
                    </DockPanel>
                    <GridSplitter Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>
                    <TextBlock Grid.Column="2" Text="Выберите сотрудника в списке слева"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="13"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                               Visibility="{Binding SelectedTeacher, Converter={x:Static conv:InverseNullToCollapsedConverter.Instance}}"/>
                    <Grid Grid.Column="2"
                          Visibility="{Binding SelectedTeacher, Converter={x:Static conv:NullToCollapsedConverter.Instance}}">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="0,0,0,52"
                                      helpers:CompactPanel.CompactAt="300">
                        <Border Style="{StaticResource TeacherCardShellStyle}"
                                Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                            <StackPanel>
                                <Border Style="{StaticResource TeacherCardHeaderStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*" MinWidth="0"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource TeacherCardAvatarStyle}" Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                                <TextBox Text="{Binding EditTeacherName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontWeight="SemiBold" FontSize="15" Padding="4,2"
                                                         BorderThickness="0,0,0,1"
                                                         Background="Transparent"
                                                         ToolTip="ФИО сотрудника"
                                                         helpers:DuplicateHighlight.IsDuplicate="{Binding IsEditTeacherDuplicate}"/>
                                                <TextBlock Text="{Binding SelectedTeacher.TypeDisplay}" Style="{StaticResource TeacherCardSubtitleStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Style="{StaticResource TeacherCardHeaderActionsStyle}" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource SidePanelIconSaveButtonStyle}"
                                                        Command="{Binding SaveTeacherCommand}"
                                                        ToolTip="Сохранить карточку"/>
                                                <Button Style="{StaticResource SidePanelIconDangerButtonStyle}"
                                                        Tag="🗑"
                                                        Command="{Binding DeleteTeacherCommand}"
                                                        ToolTip="Удалить сотрудника"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <StackPanel Style="{StaticResource TeacherCardBodyStyle}">
                                    <Border Style="{StaticResource TeacherCardSectionStyle}">
                                        <StackPanel>
                                            <ContentControl Content="Основные данные"
                                                            ContentTemplate="{StaticResource TeacherCardSectionHeaderTemplate}"/>
                                            <TextBlock Text="ФИО" Style="{StaticResource FormFieldLabelStyle}"/>
                                            <TextBox Style="{StaticResource SidePanelFieldStyle}"
                                                     Text="{Binding EditTeacherName, UpdateSourceTrigger=PropertyChanged}"
                                                     helpers:DuplicateHighlight.IsDuplicate="{Binding IsEditTeacherDuplicate}"/>
                                            <TextBlock Text="{Binding EditTeacherDuplicateHint}" FontSize="10" Foreground="#DC2626"
                                                       Visibility="{Binding EditTeacherDuplicateHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8"
                                                        Visibility="{Binding EditTeacherSuggestionHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                                                <TextBlock Text="{Binding EditTeacherSuggestionHint}" FontSize="10"
                                                           Foreground="#B45309" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Content="Применить" Style="{StaticResource SmallButtonStyle}" Margin="8,0,0,0"
                                                        Command="{Binding ApplyEditTeacherSuggestionCommand}"
                                                        ToolTip="Подставить предложенное ФИО"/>
                                            </StackPanel>
                                            <TextBlock Text="Тип" Style="{StaticResource FormFieldLabelStyle}"/>
                                            <ComboBox Style="{StaticResource SidePanelComboStyle}"
