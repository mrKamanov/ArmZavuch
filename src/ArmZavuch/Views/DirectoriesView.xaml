                                                                <Button DockPanel.Dock="Right" Content="×"
                                                                        Style="{StaticResource IconButtonStyle}"
                                                                        Command="{Binding DataContext.RemoveStatusPeriodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
