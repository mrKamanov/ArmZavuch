<UserControl x:Class="ArmZavuch.Views.DispatcherReplacementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters">
    <UserControl.Resources>
        <Style x:Key="DispatcherLessonRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding NeedsReplacement}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasAssignedReplacement}" Value="True">
                    <Setter Property="Background" Value="#F0FDF4"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AbsentTeachersGridStyle" TargetType="DataGrid" BasedOn="{StaticResource CrudDataGridStyle}">
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ColumnWidth" Value="Auto"/>
        </Style>
        <Style x:Key="DispatcherScheduleGridStyle" TargetType="DataGrid" BasedOn="{StaticResource CrudDataGridStyle}">
            <Setter Property="RowStyle" Value="{StaticResource DispatcherLessonRowStyle}"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
        </Style>
        <Style x:Key="JournalGridCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="None"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style x:Key="DispatcherJournalGridStyle" TargetType="DataGrid" BasedOn="{StaticResource CrudDataGridStyle}">
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
        </Style>
        <Style x:Key="JournalSubstitutionGridStyle" TargetType="DataGrid" BasedOn="{StaticResource DispatcherJournalGridStyle}">
            <Setter Property="ColumnWidth" Value="SizeToCells"/>
        </Style>
        <Style x:Key="JournalAbsenceGridStyle" TargetType="DataGrid" BasedOn="{StaticResource DispatcherJournalGridStyle}">
            <Setter Property="ColumnWidth" Value="SizeToCells"/>
        </Style>
        <Style x:Key="JournalKpiCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
        <Style x:Key="JournalChartCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="MinHeight" Value="132"/>
        </Style>
        <Style x:Key="DispatcherCandidateRowStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="White" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="10,8" Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="StaffBarChartItemTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="148"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           ToolTip="{Binding Label}"/>
                <Border Grid.Column="1" Background="#E2E8F0" CornerRadius="3" Height="14"
                        Margin="6,0" VerticalAlignment="Center">
                    <Border Background="#3B82F6" HorizontalAlignment="Left" CornerRadius="3"
                            Height="14" Width="{Binding BarPixelWidth}"/>
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding Caption}" FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="StaffAbsenteeBarChartItemTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="148"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           ToolTip="{Binding Label}"/>
                <Border Grid.Column="1" Background="#E2E8F0" CornerRadius="3" Height="14"
                        Margin="6,0" VerticalAlignment="Center">
                    <Border Background="#F97316" HorizontalAlignment="Left" CornerRadius="3"
                            Height="14" Width="{Binding BarPixelWidth}"/>
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding Caption}" FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="DispatcherCandidateTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TeacherName}" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="{Binding CurrentLocation}" FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding RoleHint}" FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                               Visibility="{Binding RoleHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    <TextBlock Text="{Binding AvailabilityHint}" FontSize="10" Foreground="#64748B"
                               Margin="0,2,0,0" FontStyle="Italic" TextWrapping="Wrap"
                               Visibility="{Binding AvailabilityHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            CornerRadius="10" Padding="8,2" Margin="0,0,0,4">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">
                            <Run Text="{Binding Score, Mode=OneWay}"/>
                            <Run Text=" б."/>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="⚠ опоздание" FontSize="10" Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Right"
                               Visibility="{Binding HasLateRisk, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock FontSize="10" Foreground="#B45309" HorizontalAlignment="Right" TextWrapping="Wrap"
                               Visibility="{Binding HasShuttleWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <Run Text="⚠ "/>
                        <Run Text="{Binding ShuttleWarningText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#B45309" HorizontalAlignment="Right"
                               Visibility="{Binding HasLoadWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <Run Text="⚠ "/>
                        <Run Text="{Binding LessonsToday, Mode=OneWay}"/>
                        <Run Text=" уроков за день"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <TabControl Style="{StaticResource ModuleTabControlStyle}">
        <TabControl.Resources>
            <Style TargetType="TabItem" BasedOn="{StaticResource ModuleTabItemStyle}"/>
        </TabControl.Resources>

        <TabItem Header="Замены на день" ToolTip="Расписание, отсутствие и назначение замен">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" MinWidth="420"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="360"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#FFF7ED" BorderBrush="#FDBA74"
                        BorderThickness="1" CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{Binding AbsentTeachersCaption}"
                                       FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="· Нажмите на строку — расписание учителя"
                                       FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ClearAllSubstitutionsForDayCommand}"
                                    Content="Сбросить все замены"
                                    Margin="16,0,0,0" VerticalAlignment="Center"
                                    ToolTip="Снять все назначенные замены на выбранную дату. Отсутствия не затрагиваются."/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding AbsentTeachersToday}"
                                  SelectedItem="{Binding SelectedAbsentTeacher}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Style="{StaticResource AbsentTeachersGridStyle}"
                                  MaxHeight="140" MinHeight="40"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  ColumnWidth="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Учитель" Binding="{Binding TeacherName}"
                                                    MinWidth="200" Width="Auto"/>
                                <DataGridTextColumn Header="Причина" Binding="{Binding StatusLabel}"
                                                    MinWidth="96" Width="Auto"/>
                                <DataGridTextColumn Header="Период" Binding="{Binding PeriodText}"
                                                    MinWidth="150" Width="Auto"/>
                                <DataGridTextColumn Header="" Width="*" IsReadOnly="True" CanUserResize="False"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Background="#FAFBFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#F1F5F9" Padding="14,10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Расписание учителя на день" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ReplacementsHint}" FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" MinWidth="280">
                                    <TextBlock Text="Учитель" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding Teachers}" DisplayMemberPath="FullName"
                                              SelectedItem="{Binding SelectedTeacher}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataGrid ItemsSource="{Binding TeacherDayLessons}" AutoGenerateColumns="False"
                                  SelectedItem="{Binding SelectedLesson}" IsReadOnly="True"
                                  Style="{StaticResource DispatcherScheduleGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Урок" Binding="{Binding DisplayLessonLabel}" Width="72"/>
                                <DataGridTextColumn Header="Время" Binding="{Binding TimeDisplay}" Width="96"/>
                                <DataGridTextColumn Header="Класс" Binding="{Binding ClassName}" Width="56"/>
                                <DataGridTextColumn Header="Предмет" Binding="{Binding SubjectName}" Width="*"/>
                                <DataGridTextColumn Header="Каб." Binding="{Binding RoomNumber}" Width="48"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding StatusLabel}" Width="140"/>
                                <DataGridTextColumn Header="Замена" Binding="{Binding ReplacementTeacherName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>

                <Border Grid.Row="1" Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <TabControl SelectedIndex="{Binding ReplacementSideTab}" Padding="8,4,8,8"
                                BorderThickness="0" Background="Transparent">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" BasedOn="{StaticResource ModuleTabItemStyle}"/>
                        </TabControl.Resources>
                        <TabItem Header="Отсутствие">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="{Binding AbsenceFormHint}" Style="{StaticResource SidePanelHelpTextStyle}" Margin="0,4,0,10"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Причина" Style="{StaticResource FormFieldLabelStyle}"/>
                                            <ComboBox SelectedValue="{Binding AbsenceType}" SelectedValuePath="Tag">
                                                <ComboBoxItem Content="Больничный" Tag="Sick"/>
                                                <ComboBoxItem Content="Отгул" Tag="Leave"/>
                                                <ComboBoxItem Content="Другое" Tag="Other"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Заметка" Style="{StaticResource FormFieldLabelStyle}"/>
                                            <TextBox Text="{Binding AbsenceNote}"/>
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="Официальное отсутствие" IsChecked="{Binding AbsenceIsOfficial}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Быстро — только выбранная дата" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding TeacherAbsentCommand}"
                                            HorizontalAlignment="Stretch" Content="Отметить на сегодня (быстро)"/>
                                    <TextBlock Text="На период" FontWeight="SemiBold" FontSize="11" Margin="0,14,0,6"/>
                                    <TextBlock Text="С даты" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding AbsencePeriodStart}" Margin="0,0,0,6"/>
                                    <CheckBox Content="Без даты окончания (открытый больничный)"
                                              IsChecked="{Binding AbsencePeriodOpenEnded}" Margin="0,0,0,6"/>
                                    <StackPanel Visibility="{Binding AbsencePeriodOpenEnded, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                                        <TextBlock Text="По дату" Style="{StaticResource FormFieldLabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding AbsencePeriodEnd}" Margin="0,0,0,6"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding MarkPeriodAbsenceCommand}"
                                            HorizontalAlignment="Stretch" Content="Отметить на период"/>
                                    <TextBlock Text="{Binding ActiveAbsencePeriodHint}" FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                                               Margin="0,10,0,0"
                                               Visibility="{Binding HasTeacherAbsenceOverride, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseAbsenceEarlyCommand}"
                                            HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                            Visibility="{Binding CanCloseAbsenceEarly, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                            Content="Закрыть досрочно (последний день — в календаре дня)"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelTeacherAbsenceCommand}"
                                            HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                            Visibility="{Binding HasTeacherAbsenceOverride, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                            Content="Снять отметку: учитель на месте с выбранной даты"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Подбор замены">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,4,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedLessonTitle}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedLessonDetail}" FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource ToolbarButtonGroupStyle}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                                    Command="{Binding LoadCandidatesCommand}" Content="Подобрать замену"/>
                                            <Border Style="{StaticResource ToolbarGroupSeparatorHorizontalStyle}"/>
                                            <Button Style="{StaticResource ToolbarGroupPrimaryItemStyle}"
                                                    Command="{Binding AssignReplacementCommand}" Content="Назначить замену"/>
                                        </StackPanel>
                                    </Border>
                                    <CheckBox Content="Официальная замена (для отчёта и доплаты)"
                                              IsChecked="{Binding ReplacementIsOfficial}" Margin="0,0,0,8"/>
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RemoveReplacementCommand}"
                                            HorizontalAlignment="Left" Margin="0,0,0,8"
                                            Visibility="{Binding CanRemoveReplacement, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                            Content="Отменить назначенную замену"/>
                                    <TextBlock Text="{Binding CandidatesHint}" FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding CandidatesHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <ListBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}"
                                                 ItemTemplate="{StaticResource DispatcherCandidateTemplate}"
                                                 ItemContainerStyle="{StaticResource DispatcherCandidateRowStyle}"
                                                 BorderThickness="0" Background="Transparent"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                        <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,8,0,6"
                                                Visibility="{Binding HasFinishedDayCandidates, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                            <StackPanel>
                                                <TextBlock Text="Уже отработали день" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Text="Можно попросить, если других нет — но между последним уроком и заменой уже прошло больше одного урока."
                                                           FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <ListBox ItemsSource="{Binding FinishedDayCandidates}" SelectedItem="{Binding SelectedCandidate}"
                                                 ItemTemplate="{StaticResource DispatcherCandidateTemplate}"
                                                 ItemContainerStyle="{StaticResource DispatcherCandidateRowStyle}"
                                                 BorderThickness="0" Background="Transparent"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 Visibility="{Binding HasFinishedDayCandidates, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Журнал и отчёт" ToolTip="Замены, отсутствия и сводка за период">
            <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="С" Style="{StaticResource FormFieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding ReportFromDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="По" Style="{StaticResource FormFieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding ReportToDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Показать"
                                        Command="{Binding LoadSubstitutionReportCommand}" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Excel"
                                        Command="{Binding ExportSubstitutionReportCommand}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding JournalHint}" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding JournalSubstitutionTotalsLine}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True" Padding="8,4,8,8">
                    <TabControl SelectedIndex="{Binding JournalReportTab}" BorderThickness="0" Background="Transparent"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" BasedOn="{StaticResource ModuleTabItemStyle}"/>
                        </TabControl.Resources>
                        <TabItem Header="Замены">
                            <DockPanel LastChildFill="True">
                            <DataGrid ItemsSource="{Binding SubstitutionReportPreview}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource JournalSubstitutionGridStyle}"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource JournalGridCellTextStyle}"/>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding DateDisplay}" MinWidth="84"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Урок" Binding="{Binding LessonNumber}" MinWidth="44"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Время" Binding="{Binding TimeDisplay}" MinWidth="92"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Смена" Binding="{Binding ShiftDisplay}" MinWidth="72"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Класс" Binding="{Binding ClassName}" MinWidth="48"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Предмет" Binding="{Binding SubjectName}" MinWidth="120"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Отсутствовал" Binding="{Binding AbsentTeacherName}" MinWidth="150"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Заменял" Binding="{Binding ReplacementTeacherName}" MinWidth="150"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Официально" Binding="{Binding OfficialLabel}" MinWidth="108"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTemplateColumn Header="" Width="40" CanUserResize="False" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="×" ToolTip="Удалить из журнала"
                                                        Style="{StaticResource RowIconDangerButtonStyle}"
                                                        Command="{Binding DataContext.DeleteSubstitutionRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </DockPanel>
                        </TabItem>
                        <TabItem Header="Отсутствия">
                            <DockPanel LastChildFill="True">
                            <DataGrid ItemsSource="{Binding AbsenceReportPreview}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource JournalAbsenceGridStyle}"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource JournalGridCellTextStyle}"/>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Учитель" Binding="{Binding TeacherName}" MinWidth="180"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Причина" Binding="{Binding StatusLabel}" MinWidth="96"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Период" Binding="{Binding PeriodDisplay}" MinWidth="168"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Дней" Binding="{Binding DaysInRange}" MinWidth="48"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Официально" Binding="{Binding OfficialLabel}" MinWidth="108"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    <DataGridTextColumn Header="Заметка" Binding="{Binding Note}" MinWidth="120"
                                                        ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            </DockPanel>
                        </TabItem>
                        <TabItem Header="Сводка">
                            <DockPanel Margin="4,6,4,4" LastChildFill="True">
                                <UniformGrid DockPanel.Dock="Top" Columns="5" Margin="0,0,0,12">
                                    <Border Style="{StaticResource JournalKpiCardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Замен всего" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding JournalSubstitutionTotal}" FontSize="20"
                                                       FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource JournalKpiCardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Официально" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding JournalOfficialSubstitutionTotal}" FontSize="20"
                                                       FontWeight="SemiBold" Foreground="#16A34A" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource JournalKpiCardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Неофициально" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding JournalUnofficialSubstitutionTotal}" FontSize="20"
                                                       FontWeight="SemiBold" Foreground="#EA580C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource JournalKpiCardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Периодов отсутствия" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding JournalAbsencePeriodCount}" FontSize="20"
                                                       FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource JournalKpiCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Педагогов в сводке" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding JournalTeacherActivityCount}" FontSize="20"
                                                       FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource JournalChartCardStyle}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="Чаще отсутствуют"
                                                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding TopAbsenteesChart}"
                                                              ItemTemplate="{StaticResource StaffAbsenteeBarChartItemTemplate}"/>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource JournalChartCardStyle}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="Чаще заменяют коллег"
                                                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding TopSubstitutorsChart}"
                                                              ItemTemplate="{StaticResource StaffBarChartItemTemplate}"/>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                </Grid>

                                <TextBlock DockPanel.Dock="Top" Text="Детализация по педагогам"
                                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>

                                <DataGrid ItemsSource="{Binding StaffActivitySummary}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          Style="{StaticResource DispatcherJournalGridStyle}"
                                          ColumnWidth="SizeToCells"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Педагог" Binding="{Binding TeacherName}" MinWidth="140"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Дней отс." Binding="{Binding AbsenceDays}" MinWidth="68"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Бол." Binding="{Binding SickDays}" MinWidth="44"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Отг." Binding="{Binding LeaveDays}" MinWidth="44"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Проч." Binding="{Binding OtherDays}" MinWidth="48"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Заменил" Binding="{Binding SubstitutionCount}" MinWidth="60"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Офиц." Binding="{Binding OfficialSubstitutionCount}" MinWidth="52"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Неофиц." Binding="{Binding UnofficialSubstitutionCount}" MinWidth="60"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Его заменяли" Binding="{Binding WasReplacedCount}" MinWidth="88"
                                                            ElementStyle="{StaticResource JournalGridCellTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
