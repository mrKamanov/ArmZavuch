                                                DecreaseCommand="{Binding DecreaseFixedLessonMinutesCommand}"
                                                IncreaseCommand="{Binding IncreaseFixedLessonMinutesCommand}"
                                                ApplyCommand="{Binding ApplyFixedLessonsCommand}"
                                                DecreaseToolTip="Меньше на 1 мин" IncreaseToolTip="Больше на 1 мин"/>
                                            <controls:DayEditorStepperRow Label="Перемены по"
                                                Value="{Binding FixedBreakMinutes}"
                                                DecreaseCommand="{Binding DecreaseFixedBreakMinutesCommand}"
                                                IncreaseCommand="{Binding IncreaseFixedBreakMinutesCommand}"
                                                ApplyCommand="{Binding ApplyFixedBreaksCommand}"
                                                DecreaseToolTip="Меньше на 1 мин" IncreaseToolTip="Больше на 1 мин"/>
                                        </StackPanel>
                                    </Border>
                                    </StackPanel>

