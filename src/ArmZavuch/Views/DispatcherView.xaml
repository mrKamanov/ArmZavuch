                                    <TextBlock Text="Здание" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding BuildingNames}"
                                              SelectedItem="{Binding EditDayBuildingFilter}" Style="{StaticResource SidePanelComboStyle}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Кабинет" Style="{StaticResource FormFieldLabelStyle}" Margin="0"/>
