                                                IncreaseCommand="{Binding IncreaseTrimBreakMinutesCommand}"
                                                ApplyCommand="{Binding ApplyShortBreaksCommand}"
                                                DecreaseToolTip="Меньше на 1 мин" IncreaseToolTip="Больше на 1 мин"/>
