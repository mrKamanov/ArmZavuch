                                                Value="{Binding MaxLessonsForDay}"
                                                DecreaseCommand="{Binding DecreaseMaxLessonsForDayCommand}"
                                                IncreaseCommand="{Binding IncreaseMaxLessonsForDayCommand}"
                                                ApplyCommand="{Binding ApplyMaxLessonsCommand}"
                                                DecreaseToolTip="Меньше на 1 урок" IncreaseToolTip="Больше на 1 урок"/>
