                                                   Visibility="{Binding IsDayRoomRequired, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}"/>
                                    </StackPanel>
                                    <ComboBox ItemsSource="{Binding FilteredDayRooms}"
