<UserControl x:Class="ArmZavuch.Views.DispatcherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:controls="clr-namespace:ArmZavuch.Views.Controls"
             xmlns:views="clr-namespace:ArmZavuch.Views">
    <UserControl.Resources>
        <conv:PositiveToVisibleConverter x:Key="PositiveToVisible"/>

        <Style x:Key="DispatcherModeTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="#F1F5F9" CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DispatcherLessonRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding NeedsReplacement}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasAssignedReplacement}" Value="True">
                    <Setter Property="Background" Value="#F0FDF4"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DispatcherScheduleGridStyle" TargetType="DataGrid" BasedOn="{StaticResource CrudDataGridStyle}">
            <Setter Property="RowStyle" Value="{StaticResource DispatcherLessonRowStyle}"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
        </Style>

        <Style x:Key="DispatcherCandidateRowStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="White" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="10,8" Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DispatcherCandidateTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TeacherName}" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="{Binding CurrentLocation}" FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding RoleHint}" FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                               Visibility="{Binding RoleHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            CornerRadius="10" Padding="8,2" Margin="0,0,0,4">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">
                            <Run Text="{Binding Score, Mode=OneWay}"/>
                            <Run Text=" б."/>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="⚠ опоздание" FontSize="10" Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Right"
                               Visibility="{Binding HasLateRisk, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock FontSize="10" Foreground="#B45309" HorizontalAlignment="Right" TextWrapping="Wrap"
                               Visibility="{Binding HasShuttleWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <Run Text="⚠ "/>
                        <Run Text="{Binding ShuttleWarningText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#B45309" HorizontalAlignment="Right"
                               Visibility="{Binding HasLoadWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <Run Text="⚠ "/>
                        <Run Text="{Binding LessonsToday, Mode=OneWay}"/>
                        <Run Text=" уроков за день"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherStatChipTemplate">
            <Border Background="{Binding AccentBackground}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8,5"
                    MinWidth="{Binding MinWidth}" Margin="0,0,6,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock Text="{Binding Value}" FontSize="17" FontWeight="Bold"
                                   Foreground="{Binding AccentForeground}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Hint}" FontSize="9" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherStatCardTemplate">
            <Border Background="{Binding AccentBackground}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="14,10"
                    MinWidth="{Binding MinWidth}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Value}" FontSize="22" FontWeight="Bold"
                               Foreground="{Binding AccentForeground}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Hint}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                    <ItemsControl ItemsSource="{Binding DetailLines}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="10" Foreground="#7F1D1D"
                                           TextWrapping="Wrap" Margin="0,0,0,4" LineHeight="14"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherMonitorColumnHeaderTemplate">
            <Border Width="152" MinWidth="152" Margin="1" Padding="6,5" CornerRadius="6"
                    BorderBrush="Transparent" BorderThickness="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#E2E8F0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ColumnKind}" Value="DynamicPause">
                                <Setter Property="Background" Value="#DCFCE7"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ColumnKind}" Value="Break">
                                <Setter Property="Background" Value="#FEF3C7"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShift}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="Lesson"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#EDE9FE"/>
                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShift}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="Break"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="#A78BFA"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShift}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="DynamicPause"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="#A78BFA"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsShiftBoundary}" Value="True">
                                <Setter Property="BorderBrush" Value="#7C3AED"/>
                                <Setter Property="BorderThickness" Value="3,1,1,1"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsNow}" Value="True">
                                <Setter Property="BorderBrush" Value="#F97316"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="2 смена" FontSize="8" FontWeight="SemiBold" Foreground="#6D28D9"
                               HorizontalAlignment="Center" Margin="0,0,0,2"
                               Visibility="{Binding IsShiftBoundary, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="10"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Time}" FontSize="9" Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    <Border Height="3" CornerRadius="2" Margin="0,4,0,0" Background="#F97316"
                            Visibility="{Binding IsNow, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherMonitorCellTemplate">
            <Border x:Name="cell" Margin="1" Padding="5,4" CornerRadius="6"
                    Width="152" MinWidth="152" MinHeight="104"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Cursor" Value="Arrow"/>
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip MaxWidth="360">
                                    <TextBlock Text="{Binding ToolTip}" TextWrapping="Wrap"/>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasLesson}" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ColumnKind}" Value="Window">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ColumnKind}" Value="Empty">
                                <Setter Property="Background" Value="#FCFCFD"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ColumnKind}" Value="DynamicPause">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Setter Property="BorderBrush" Value="#BBF7D0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ColumnKind}" Value="Break">
                                <Setter Property="Background" Value="#FFFBEB"/>
                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="Empty"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#F5F3FF"/>
                                <Setter Property="BorderBrush" Value="#DDD6FE"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="Window"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#F5F3FF"/>
                                <Setter Property="BorderBrush" Value="#DDD6FE"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                    <Condition Binding="{Binding HasLesson}" Value="True"/>
                                    <Condition Binding="{Binding HasConflict}" Value="False"/>
                                    <Condition Binding="{Binding StatusKind}" Value="Normal"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#FAF5FF"/>
                                <Setter Property="BorderBrush" Value="#DDD6FE"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="Break"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                    <Condition Binding="{Binding ColumnKind}" Value="DynamicPause"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="Pending">
                                <Setter Property="Background" Value="#FEF2F2"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="Replacement">
                                <Setter Property="Background" Value="#F0FDF4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="Cancelled">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="Unavailability">
                                <Setter Property="Background" Value="#F5F3FF"/>
                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="Transition">
                                <Setter Property="Background" Value="#FFF7ED"/>
                                <Setter Property="BorderBrush" Value="#FB923C"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasRoomSharedWarning}" Value="True"/>
                                    <Condition Binding="{Binding HasConflict}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#FFFBEB"/>
                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="360">
                                            <TextBlock Text="{Binding RoomSharedHint}" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="360">
                                            <StackPanel>
                                                <TextBlock Text="Конфликт" FontWeight="SemiBold" Foreground="#B91C1C"/>
                                                <TextBlock Text="{Binding ConflictHint}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding ToolTip}" TextWrapping="Wrap" Margin="0,6,0,0"
                                                           Foreground="#64748B" FontSize="11"
                                                           Visibility="{Binding ToolTip, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectMonitorCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="4,0,0,4"
                            Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                            Visibility="{Binding HasLesson, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                    <StackPanel Grid.Column="1" Margin="4,3,3,3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel x:Name="contentPanel" Grid.Row="0" VerticalAlignment="Center">
                                <TextBlock x:Name="primaryLine" Text="{Binding PrimaryLine}"
                                           FontSize="12" FontWeight="SemiBold" LineHeight="14"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="secondaryLine" Text="{Binding SecondaryLine}"
                                           FontSize="11" LineHeight="13"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"
                                           Visibility="{Binding SecondaryLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                            </StackPanel>
                            <TextBlock x:Name="statusLine" Grid.Row="1" Text="{Binding StatusLine}"
                                       FontSize="10" FontWeight="SemiBold" LineHeight="13"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                       Visibility="{Binding StatusLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding StatusKind}" Value="Pending">
                    <Setter TargetName="statusLine" Property="Foreground" Value="#B91C1C"/>
                    <Setter TargetName="secondaryLine" Property="Foreground" Value="#B91C1C"/>
                    <Setter TargetName="secondaryLine" Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="Replacement">
                    <Setter TargetName="statusLine" Property="Foreground" Value="#15803D"/>
                    <Setter TargetName="secondaryLine" Property="Foreground" Value="#15803D"/>
                    <Setter TargetName="secondaryLine" Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="Unavailability">
                    <Setter TargetName="primaryLine" Property="Foreground" Value="#6D28D9"/>
                    <Setter TargetName="secondaryLine" Property="Foreground" Value="#7C3AED"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasLesson}" Value="False">
                    <Setter TargetName="primaryLine" Property="HorizontalAlignment" Value="Center"/>
                    <Setter TargetName="primaryLine" Property="TextAlignment" Value="Center"/>
                    <Setter TargetName="secondaryLine" Property="HorizontalAlignment" Value="Center"/>
                    <Setter TargetName="secondaryLine" Property="TextAlignment" Value="Center"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="Transition">
                    <Setter TargetName="statusLine" Property="Foreground" Value="#C2410C"/>
                    <Setter TargetName="statusLine" Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherMonitorRowTemplate">
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="148" MinWidth="148"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#F1F5F9" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="0" Margin="0,0,2,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="4" CornerRadius="6,0,0,6"
                                Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                Visibility="{Binding BuildingColorHex, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                        <StackPanel Grid.Column="1" Margin="8,6,8,6" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="11"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                            <TextBlock Text="{Binding SubLabel}" FontSize="9" Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding SubLabel, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource DispatcherMonitorCellTemplate}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherDayEditorSectionTemplate">
            <StackPanel Margin="0,0,0,14">
                <Border Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1"
                        CornerRadius="8" Padding="10,8" Margin="0,0,0,8"
                        Visibility="{Binding IsShiftHeader, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13"
                                   Foreground="#1E40AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SubTitle}" FontSize="11" Foreground="#1E3A8A"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"
                                   Visibility="{Binding SubTitle, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding IsShiftHeader, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SubTitle}" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SubTitle, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="148" MinWidth="148"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#E2E8F0" CornerRadius="6" Padding="8,8" Margin="0,0,2,0">
                            <TextBlock Text="Класс / урок →" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Columns}"
                                      ItemTemplate="{StaticResource DispatcherMonitorColumnHeaderTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:DayEditorGridRowView/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DispatcherMonitorSectionTemplate">
            <StackPanel Margin="0,0,0,14">
                <Border Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1"
                        CornerRadius="8" Padding="10,8" Margin="0,0,0,8"
                        Visibility="{Binding IsShiftHeader, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13"
                                   Foreground="#1E40AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SubTitle}" FontSize="11" Foreground="#1E3A8A"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"
                                   Visibility="{Binding SubTitle, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding IsShiftHeader, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SubTitle}" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SubTitle, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="148" MinWidth="148"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#E2E8F0" CornerRadius="6" Padding="8,8" Margin="0,0,2,0">
                            <TextBlock Text="Строка / урок →" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Columns}"
