                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Или шаблон звонков целиком" Style="{StaticResource DayEditorSubsectionTitleStyle}"/>
                                    <TextBlock Text="{Binding BellsHint}" Style="{StaticResource DayEditorHintTextStyle}"/>
                                    <ComboBox ItemsSource="{Binding BellTemplateNames}"
                                              Text="{Binding SelectedBellTemplate, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True" Style="{StaticResource SidePanelComboStyle}"/>
                                    <Button Style="{StaticResource SidePanelStretchButtonStyle}"
                                            Command="{Binding ShortenedDayCommand}"
                                            Content="Применить шаблон"/>
                                    <Button Style="{StaticResource SidePanelStretchButtonStyle}"
                                            Command="{Binding OpenBellsDirectoryCommand}"
                                            Content="Настроить звонки…"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TeacherCardSectionStyle}">
                                <StackPanel>
                                    <ContentControl Content="Перестановки и отмена"
                                                    ContentTemplate="{StaticResource TeacherCardSectionHeaderTemplate}"/>
                                    <TextBlock Text="Поменять с" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding SwapLessonOptions}" DisplayMemberPath="SwapDisplayLine"
                                              SelectedItem="{Binding SelectedSwapLesson}" Style="{StaticResource SidePanelComboStyle}"/>
                                    <Button Style="{StaticResource SidePanelStretchButtonStyle}"
                                            Command="{Binding SwapLessonsCommand}"
                                            Content="Поменять местами"/>

                                    <TextBlock Text="Перенести на урок №" Style="{StaticResource FormFieldLabelStyle}" Margin="0,4,0,4"/>
                                    <Grid Style="{StaticResource DayEditorActionRowGridStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding MoveToLessonNumber}"
                                                 Style="{StaticResource DayEditorInlineNumberBoxStyle}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Style="{StaticResource SidePanelStretchButtonStyle}"
                                                Command="{Binding MoveLessonCommand}" Content="Перенести" Margin="0"/>
                                    </Grid>

                                    <TextBlock Text="Отмена у класса" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <TextBlock Text="Или выберите урок в сетке и нажмите «Отменить этот урок»."
                                               Style="{StaticResource DayEditorHintTextStyle}" Margin="0,0,0,6"/>
                                    <Grid Style="{StaticResource DayEditorActionRowGridStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding Classes}" DisplayMemberPath="DisplayName"
                                                  SelectedItem="{Binding SelectedClass}" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding CancelLessonsCount}"
                                                 Style="{StaticResource DayEditorInlineNumberBoxStyle}" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="2" Text="посл." VerticalAlignment="Center"
                                                   Style="{StaticResource SidePanelInlineLabelStyle}"/>
                                    </Grid>
                                    <Button Style="{StaticResource SidePanelStretchButtonStyle}"
                                            Command="{Binding CancelLastLessonsCommand}"
                                            Content="Отменить последние уроки"/>

                                    <TextBlock Text="История правок" Style="{StaticResource FormFieldLabelStyle}" Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding LastDayChangeHint}" Style="{StaticResource DayEditorHintTextStyle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding DayResetHint}" Style="{StaticResource DayEditorHintTextStyle}"/>
                                    <Border Style="{StaticResource ToolbarButtonGroupStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                                    Command="{Binding UndoLastDayChangeCommand}"
                                                    Content="↩ Отменить последнее"/>
                                            <Border Style="{StaticResource ToolbarGroupSeparatorHorizontalStyle}"/>
                                            <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                                    Command="{Binding ResetDayChangesCommand}"
                                                    Content="⟲ Сбросить день"/>
                                        </StackPanel>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding DayOverrides}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding DisplayLine}" FontSize="10"
                                                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </controls:ScrollableTabContent>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                CornerRadius="8" Padding="8,6" Margin="0,10,0,0">
            <TextBlock Text="{Binding FooterHint}" FontSize="10" Foreground="#0369A1" TextWrapping="Wrap" LineHeight="14"/>
        </Border>

        <Border Grid.Row="1" Background="#FAFBFC" Margin="0,8,0,0"
                Visibility="{Binding IsSchoolDay, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Уроков в этот день нет" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding DayStatusText}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
