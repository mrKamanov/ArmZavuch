                                <Run Text="Без замены: "/>
                                <Run Text="{Binding PendingReplacements, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Дата:" Style="{StaticResource FormFieldLabelStyle}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Style="{StaticResource SidePanelDatePickerStyle}" Width="150"
                                    SelectedDate="{Binding SelectedDate}"/>
                        <Border Margin="12,0,0,0" Padding="8,4" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}"
                                Background="{Binding NearestCalendarAccentBackground}"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasNearestCalendarEvent, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding NearestCalendarLabel}" FontSize="11"
                                           Foreground="{Binding NearestCalendarAccentForeground}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding NearestCalendarValue}" FontSize="14" FontWeight="Bold"
                                           Foreground="{Binding NearestCalendarAccentForeground}"
                                           Margin="6,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding NearestCalendarHint}" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,0" Padding="8,4" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}"
                                Background="{Binding PeriodGradeReminderAccentBackground}"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasPeriodGradeReminder, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PeriodGradeReminderLabel}" FontSize="11"
                                           Foreground="{Binding PeriodGradeReminderAccentForeground}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PeriodGradeReminderValue}" FontSize="14" FontWeight="Bold"
                                           Foreground="{Binding PeriodGradeReminderAccentForeground}"
                                           Margin="6,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PeriodGradeReminderHint}" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding DaySummaryText}" Margin="16,0,0,0" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                   Visibility="{Binding StatusMessage, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource ToolbarButtonGroupStyle}" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ToolbarGroupItemStyle}" Command="{Binding RefreshCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Обновить" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                        <Button Style="{StaticResource ToolbarGroupItemStyle}" Command="{Binding ExportExcelCommand}">
                            <TextBlock Text="Excel" VerticalAlignment="Center"/>
                        </Button>
                        <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                        <Button Style="{StaticResource ToolbarGroupItemStyle}" Command="{Binding CopyImageCommand}"
                                  ToolTip="Картинка + текст в буфер — для чата и почты (Ctrl+Shift+C)">
                            <TextBlock Text="В буфер" VerticalAlignment="Center"/>
                        </Button>
                        <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                        <Button Style="{StaticResource ToolbarGroupItemStyle}" Command="{Binding SaveImageCommand}"
                                  ToolTip="Сохранить лист замен как PNG">
                            <TextBlock Text="PNG" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveSection}"
                    Style="{StaticResource ModuleTabControlStyle}" Margin="0,8,0,0"
                    Visibility="{Binding IsSchoolDay, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModuleTabItemStyle}"/>
            </TabControl.Resources>

            <TabItem ToolTip="Сетка по звонкам: 1 класс, начальная 2–4 и 2–11 — отдельные блоки; при двухсменке — по сменам. Цвет полоски — здание.">
                <TabItem.Header>
                    <TextBlock Text="Монитор"/>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="188"/>
                            </Grid.ColumnDefinitions>
                            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" VerticalAlignment="Top">
                                <ItemsControl ItemsSource="{Binding StatItems}"
                                              ItemTemplate="{StaticResource DispatcherStatChipTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                                        Margin="8,2,8,0">
                                <TextBlock Text="Строки:" VerticalAlignment="Center" Margin="0,0,6,0"
                                           Style="{StaticResource SidePanelInlineLabelStyle}" FontSize="11"/>
                                <ListBox SelectedValue="{Binding MonitorMode}" SelectedValuePath="Tag"
                                         BorderThickness="0" Background="Transparent" VerticalAlignment="Center">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource DispatcherModeTabItemStyle}"/>
                                    </ListBox.ItemContainerStyle>
                                    <ListBoxItem Content="Педагоги" Tag="Teachers"/>
                                    <ListBoxItem Content="Классы" Tag="Classes"/>
                                    <ListBoxItem Content="Кабинеты" Tag="Buildings"/>
                                </ListBox>
                            </StackPanel>
                            <Border Grid.Column="2" Background="#FEF9C3" BorderBrush="#FACC15"
                                    BorderThickness="1" CornerRadius="8" Padding="8,6" VerticalAlignment="Top">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="📌 Заметка" FontWeight="SemiBold" FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <TextBox Grid.Row="1" Text="{Binding DayNoteText, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="44"
                                             VerticalScrollBarVisibility="Auto" Padding="6,4" FontSize="11"
                                             ToolTip="{Binding DayNoteHint}"
                                             LostFocus="DayNoteBox_LostFocus"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <Border Grid.Row="1" Margin="0,4,0,0" Padding="8,4" CornerRadius="6"
                                Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                Visibility="{Binding HasPendingReplacementDetails, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding PendingReplacementLines}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="10" Foreground="#991B1B" Margin="0,0,12,0"
                                                       Text="{Binding StringFormat='• {0}'}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Background="#FAFBFC" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" ClipToBounds="True" MinHeight="200">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="4">
                            <ItemsControl ItemsSource="{Binding MonitorSections}"
                                          ItemTemplate="{StaticResource DispatcherMonitorSectionTemplate}"/>
                        </ScrollViewer>
                    </Border>

                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="6,3" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="4" Height="12" Background="#94A3B8" Margin="0,0,5,0"/>
                                <TextBlock Text="полоска — здание" FontSize="9"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                CornerRadius="6" Padding="6,3" Margin="0,0,6,0">
                            <TextBlock Text="🤒/📋 нужна замена · → заменяющий" FontSize="9" Foreground="#991B1B"/>
                        </Border>
                        <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
                                CornerRadius="6" Padding="6,3" Margin="0,0,6,0">
                            <TextBlock Text="замена назначена" FontSize="9" Foreground="#15803D"/>
                        </Border>
                        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"
                                CornerRadius="6" Padding="6,3" Margin="0,0,6,0">
                            <TextBlock Text="окно" FontSize="9" Foreground="#64748B"/>
                        </Border>
                        <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                CornerRadius="6" Padding="6,3" Margin="0,0,6,0">
                            <TextBlock Text="перемена" FontSize="9" Foreground="#92400E"/>
                        </Border>
                        <Border Background="#DCFCE7" BorderBrush="#BBF7D0" BorderThickness="1"
                                CornerRadius="6" Padding="6,3" Margin="0,0,6,0">
                            <TextBlock Text="дин. пауза" FontSize="9" Foreground="#166534"/>
                        </Border>
                        <Border Background="White" BorderBrush="#F97316" BorderThickness="2"
                                CornerRadius="6" Padding="6,3">
                            <TextBlock Text="оранжевая рамка — сейчас" FontSize="9" Foreground="#C2410C"/>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Замены" ToolTip="Подбор замен и расписание учителя">
                <views:DispatcherReplacementsView/>
            </TabItem>

            <TabItem Header="Конструктор дня" ToolTip="Перестановки, звонки, кабинеты на дату">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="400" MinWidth="340" MaxWidth="460"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FAFBFC" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top" Padding="12,10" Background="#F1F5F9"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="Расписание на выбранную дату" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DayEditorGridHint}" FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DayEditorSelectionHint}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"
                                               Visibility="{Binding DayEditorSelectionHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                            CornerRadius="6" Padding="8,6" Margin="0,0,8,0"
                                            Visibility="{Binding HasDayShiftWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                        <StackPanel>
                                            <TextBlock Foreground="#92400E" FontWeight="SemiBold" FontSize="10">
                                                <Run Text="⚠ "/>
                                                <Run Text="{Binding DayShiftSummary}"/>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding DayShiftMessages}" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#78350F"
                                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <WrapPanel>
                                        <TextBlock Text="Показать:" VerticalAlignment="Center" Margin="0,0,8,4"
                                                   Style="{StaticResource SidePanelInlineLabelStyle}"/>
                                        <ListBox SelectedValue="{Binding DayEditorScope}" SelectedValuePath="Tag"
                                                 BorderThickness="0" Background="Transparent" Margin="0,0,0,4">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource DispatcherModeTabItemStyle}"/>
                                            </ListBox.ItemContainerStyle>
                                            <ListBoxItem Content="Все классы" Tag="All"/>
                                            <ListBoxItem Content="Класс" Tag="Class"/>
                                            <ListBoxItem Content="Здание" Tag="Building"/>
                                        </ListBox>
                                    </WrapPanel>
                                    <ComboBox ItemsSource="{Binding Classes}" DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding DayEditorClass}" Width="160" HorizontalAlignment="Left"
                                              Margin="0,4,0,0"
                                              Visibility="{Binding IsDayEditorClassScope, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                    <ComboBox ItemsSource="{Binding BuildingNames}"
                                              SelectedItem="{Binding DayEditorBuildingName}" Width="200"
                                              HorizontalAlignment="Left" Margin="0,4,0,0"
                                              Visibility="{Binding IsDayEditorBuildingScope, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer x:Name="DayEditorScroll" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto" Padding="6"
                                          PreviewMouseDown="DayEditorScroll_PreviewMouseDown">
                                <ItemsControl ItemsSource="{Binding DayEditorSections}"
                                              ItemTemplate="{StaticResource DispatcherDayEditorSectionTemplate}"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>

                    <controls:ScrollableTabContent Grid.Column="2">
                        <StackPanel>
                            <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,10">
                                <TextBlock Text="{Binding ModuleHint}" Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"/>
                            </Border>

                            <Border Style="{StaticResource TeacherCardSectionStyle}">
                                <StackPanel>
                                    <ContentControl Content="Урок на день"
                                                    ContentTemplate="{StaticResource TeacherCardSectionHeaderTemplate}"/>
                                    <Border Style="{StaticResource DayEditorSelectionCardStyle}"
                                            Visibility="{Binding HasSelectedLesson, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedLessonTitle}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedLessonDetail}" FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedLessonTitle}" FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"
                                               Visibility="{Binding HasSelectedLesson, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}"/>

                                    <Button Style="{StaticResource SidePanelStretchButtonStyle}"
                                            Command="{Binding CancelSelectedLessonCommand}"
                                            Content="Отменить этот урок"
                                            Margin="0,0,0,10"
                                            Visibility="{Binding CanCancelSelectedLesson, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>

                                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                            CornerRadius="8" Padding="8,6" Margin="0,0,0,10"
                                            Visibility="{Binding HasDayShiftWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                        <StackPanel>
                                            <TextBlock Foreground="#92400E" FontWeight="SemiBold" FontSize="10">
                                                <Run Text="⚠ "/>
                                                <Run Text="{Binding DayShiftSummary}"/>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding DayShiftMessages}" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#78350F"
                                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                            CornerRadius="8" Padding="8,6" Margin="0,0,0,10"
                                            Visibility="{Binding HasDayTransitionWarning, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                        <StackPanel>
                                            <TextBlock Foreground="#92400E" FontWeight="SemiBold" FontSize="10">
                                                <Run Text="↔ "/>
                                                <Run Text="{Binding DayTransitionSummary}"/>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding DayTransitionMessages}" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#78350F"
                                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

