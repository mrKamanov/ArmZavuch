                                    <Button Style="{StaticResource SidePanelStretchButtonStyle}"
                                            Command="{Binding ApplyDaySlotEditCommand}"
                                            Content="Применить на этот день" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TeacherCardSectionStyle}">
                                <StackPanel>
                                    <ContentControl Content="Сокращение на день"
                                                    ContentTemplate="{StaticResource TeacherCardSectionHeaderTemplate}"/>
                                    <TextBlock Text="{Binding DayChangesHint}" Style="{StaticResource DayEditorHintTextStyle}"/>
                                    <TextBlock Text="{Binding ShortenedDayStatus}" Style="{StaticResource DayEditorActiveStatusStyle}"
                                               Visibility="{Binding IsShortenedDayActive, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>

                                    <StackPanel Grid.IsSharedSizeScope="True">
                                    <Border Style="{StaticResource DayEditorSubsectionStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Сократить на" Style="{StaticResource DayEditorSubsectionTitleStyle}"/>
