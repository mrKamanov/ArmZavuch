<UserControl x:Class="ArmZavuch.Views.InstructionUiSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel MaxWidth="280" Margin="0,0,12,0">
        <Border Padding="10,8" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
            <Grid>
                <Border x:Name="PrimaryButton" Background="{StaticResource PrimaryBrush}" CornerRadius="6"
                        Padding="14,7" Visibility="Collapsed">
                    <TextBlock Foreground="White" FontSize="13"/>
                </Border>
                <Border x:Name="SecondaryButton" Background="{StaticResource SecondaryBrush}" CornerRadius="6"
                        Padding="14,7" Visibility="Collapsed">
                    <TextBlock Foreground="White" FontSize="13"/>
                </Border>
                <Border x:Name="DangerButton" Background="{StaticResource DangerBrush}" CornerRadius="6"
                        Padding="14,7" Visibility="Collapsed">
                    <TextBlock Foreground="White" FontSize="13"/>
                </Border>
                <StackPanel x:Name="SavePanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock x:Name="SaveGlyph" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Border x:Name="GridCell" CornerRadius="4" BorderThickness="2" Padding="8,6" MinWidth="88"
                        Visibility="Collapsed">
                    <TextBlock x:Name="GridCellText" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="LessonCell" CornerRadius="4" BorderThickness="1" Padding="8,6" MinWidth="120"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="LessonTitle" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="LessonSub" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border x:Name="Badge" Style="{StaticResource StatusBadgeDangerStyle}" Visibility="Collapsed">
                    <TextBlock x:Name="BadgeText" Foreground="{StaticResource DangerBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <StackPanel x:Name="DragHint" Orientation="Horizontal" Visibility="Collapsed">
                    <Ellipse Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush x:Name="DragEllipseFill" Color="#22C55E"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="DragHintText" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                </StackPanel>
                <StackPanel x:Name="BuildingStripePanel" Orientation="Horizontal" Visibility="Collapsed">
                    <Border Width="4" Height="36" CornerRadius="2" Background="#2563EB" Margin="0,0,8,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="5«А» · мат." FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="полоска = здание" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <TextBlock x:Name="CaptionBlock" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                   TextWrapping="Wrap" Margin="0,6,0,0"/>
    </StackPanel>
</UserControl>
