<UserControl x:Class="ArmZavuch.Views.InstructionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:help="clr-namespace:ArmZavuch.Services.Help"
             xmlns:views="clr-namespace:ArmZavuch.Views"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <UserControl.Resources>
        <Style x:Key="HelpSidebarTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="HelpArticleTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="HelpHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="HelpParagraphStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="HelpListItemStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="HelpIntroTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Margin" Value="0,6,0,12"/>
        </Style>
        <Style x:Key="HelpRouteTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style x:Key="HelpRouteHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="LineHeight" Value="16"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryHoverBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <ControlTemplate x:Key="HelpRouteButtonTemplate" TargetType="Button">
            <Border x:Name="border"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                    <Setter TargetName="border" Property="BorderBrush" Value="#BFDBFE"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                    <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="HelpRouteButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="MinWidth" Value="148"/>
            <Setter Property="MaxWidth" Value="200"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Template" Value="{StaticResource HelpRouteButtonTemplate}"/>
        </Style>
        <Style x:Key="HelpRelatedButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="HelpBlockItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <DataTemplate DataType="{x:Type help:InstructionHeadingBlock}">
            <TextBlock Text="{Binding Text}" Style="{StaticResource HelpHeadingStyle}" HorizontalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type help:InstructionParagraphBlock}">
            <TextBlock Text="{Binding Text}" Style="{StaticResource HelpParagraphStyle}" HorizontalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type help:InstructionBulletBlock}">
            <StackPanel Margin="0,0,0,10" HorizontalAlignment="Stretch">
                <ItemsControl ItemsSource="{Binding Items}" HorizontalContentAlignment="Stretch"
                              ItemContainerStyle="{StaticResource HelpBlockItemContainerStyle}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,0,0,6" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MinWidth="0"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding}" Style="{StaticResource HelpListItemStyle}" Margin="0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type help:InstructionStepsBlock}">
            <StackPanel Margin="0,0,0,10" HorizontalAlignment="Stretch">
                <ItemsControl ItemsSource="{Binding Steps}" HorizontalContentAlignment="Stretch"
                              ItemContainerStyle="{StaticResource HelpBlockItemContainerStyle}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MinWidth="0"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="→" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding}" Style="{StaticResource HelpListItemStyle}" Margin="0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type help:InstructionImportantBlock}">
            <Border Background="#FFFBEB" BorderBrush="#F97316" BorderThickness="3,0,0,0"
                    Padding="14,12,14,12" Margin="0,4,0,14" HorizontalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Stretch">
                    <TextBlock Text="Важно" FontSize="11" FontWeight="SemiBold"
                               Foreground="#C2410C" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Text}" Style="{StaticResource HelpParagraphStyle}" Margin="0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type help:InstructionUiSampleBlock}">
            <views:InstructionUiSampleView SampleKind="{Binding Kind}" SampleText="{Binding Text}"
                                           Caption="{Binding Caption}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type help:InstructionUiGalleryBlock}">
            <WrapPanel Margin="0,0,0,14" HorizontalAlignment="Stretch">
                <ItemsControl ItemsSource="{Binding Samples}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type help:InstructionUiSampleBlock}">
                            <views:InstructionUiSampleView SampleKind="{Binding Kind}" SampleText="{Binding Text}"
                                                           Caption="{Binding Caption}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ModuleHeaderBarStyle}">
            <StackPanel>
                <TextBlock Text="Инструкция" Style="{StaticResource ModulePageTitleStyle}"/>
                <TextBlock Style="{StaticResource HelpIntroTextStyle}"
                           Text="Справка по шагам: что нажимать, в каком порядке, что будет дальше. Выберите тему слева или воспользуйтесь поиском."/>

                <TextBlock Text="Срочно нужно" Style="{StaticResource HelpSidebarTitleStyle}"/>
                <ItemsControl ItemsSource="{Binding QuickRoutes}" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource HelpRouteButtonStyle}"
                                    Command="{Binding DataContext.SelectArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding ArticleId}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource HelpRouteTitleStyle}"/>
                                    <TextBlock Text="{Binding Hint}" Style="{StaticResource HelpRouteHintStyle}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                    <TextBlock Text="Поиск по справке" Style="{StaticResource HelpSidebarTitleStyle}" Margin="0,8,0,4"/>
                    <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13"
                             Tag="Поиск по справке…"/>
                    <Button Grid.Column="1" Content="✕" Margin="8,0,0,0" Padding="10,6"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding IsSearchActive, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CrudFormPanelStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                    <TreeView x:Name="TopicTreeView"
                              ItemsSource="{Binding TopicTree}"
                              SelectedItemChanged="TopicTree_OnSelectedItemChanged"
                              BorderThickness="0" Background="Transparent"
                              Visibility="{Binding IsSearchActive, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding" Value="2"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Padding="0,2"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <ListBox ItemsSource="{Binding SearchResults}"
                             BorderThickness="0" Background="Transparent"
                             Visibility="{Binding IsSearchActive, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4"
                                        Command="{Binding DataContext.SelectArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}">
                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap"/>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="Ничего не найдено. Попробуйте другое слово: «замена», «черновик», «нагрузка»."
                               TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="4,8,0,0"
                               Visibility="{Binding ShowSearchEmpty, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding VersionLabel}" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                        <Button Content="Проверить обновления"
                                Command="{Binding CheckForUpdatesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CrudFormPanelStyle}" Padding="20,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel HorizontalAlignment="Stretch"
                                Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                        <TextBlock Text="{Binding SelectedArticle.Title, FallbackValue='Выберите тему слева'}"
                                   Style="{StaticResource HelpArticleTitleStyle}"/>

                        <Button Content="{Binding OpenModuleLabel}"
                                Command="{Binding OpenModuleCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                Visibility="{Binding CanOpenModule, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>

                        <ItemsControl ItemsSource="{Binding SelectedArticle.Blocks}"
                                      HorizontalContentAlignment="Stretch"
                                      ItemContainerStyle="{StaticResource HelpBlockItemContainerStyle}"/>

                        <StackPanel Margin="0,20,0,0"
                                    Visibility="{Binding HasRelatedArticles, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                            <TextBlock Text="См. также" Style="{StaticResource HelpSidebarTitleStyle}"/>
                            <ItemsControl ItemsSource="{Binding RelatedArticles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Title}" Style="{StaticResource HelpRelatedButtonStyle}"
                                                Command="{Binding DataContext.SelectArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
