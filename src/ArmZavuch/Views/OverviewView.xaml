<UserControl x:Class="ArmZavuch.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:views="clr-namespace:ArmZavuch.Views"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding LoadCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Сводка расписания" Style="{StaticResource ModulePageTitleStyle}"/>
            <TextBlock Text="Клик по ячейке — переход в другой срез. Внутри дня уроки идут сверху вниз по времени звонков. Ctrl+колёсико — масштаб."
                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" Margin="0,4,0,8"/>

            <ListBox SelectedValue="{Binding OverviewMode}" SelectedValuePath="Tag"
                     BorderThickness="0" Background="Transparent" Margin="0,0,0,8">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="14,7"/>
                        <Setter Property="Margin" Value="0,0,6,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="#F1F5F9" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem Content="Вся школа" Tag="School"/>
                <ListBoxItem Content="Педагоги" Tag="Teachers"/>
                <ListBoxItem Content="Классы" Tag="Classes"/>
                <ListBoxItem Content="Здания" Tag="Buildings"/>
            </ListBox>

            <WrapPanel>
                <TextBlock Text="Шаблон:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <ComboBox ItemsSource="{Binding Templates}" DisplayMemberPath="DisplayName"
                          SelectedItem="{Binding SelectedTemplate}" Width="220" Margin="0,0,12,4"/>
                <CheckBox Content="Показать перемены" IsChecked="{Binding ShowBreaksInOverview}"
                          Visibility="{Binding IsSchoolOverviewMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                          VerticalAlignment="Center" Margin="0,0,12,4"
                          ToolTip="Вставить строки перемен между уроками по шаблону звонков"/>
                <Button Content="Скачать Excel" Command="{Binding ExportExcelCommand}" Margin="0,0,8,4"
                        ToolTip="4 листа: вся школа (с переменами), педагоги, классы, здания"/>
                <Button Content="Обновить" Command="{Binding LoadCommand}" Margin="0,0,8,4"
                        Style="{StaticResource SecondaryButtonStyle}" ToolTip="F5"/>
                <Button Content="Сброс вида" Click="OverviewResetView_Click" Margin="0,0,12,4"
                        Style="{StaticResource SecondaryButtonStyle}" ToolTip="Масштаб 100%"/>
                <TextBlock Text="{Binding OverviewCaption}" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
            </WrapPanel>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                        Visibility="{Binding OverviewFilterPath, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                <TextBlock Text="Фильтр:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding OverviewFilterPath}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Показать всё" Command="{Binding ResetOverviewFilterCommand}"
                        Style="{StaticResource SmallButtonStyle}" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Border Background="#FAFBFC" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                <ScrollViewer x:Name="OverviewScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="OverviewScroll_PreviewMouseWheel">
                <StackPanel Margin="4">
                    <StackPanel.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding OverviewZoom}" ScaleY="{Binding OverviewZoom}"/>
                    </StackPanel.LayoutTransform>

                    <ItemsControl ItemsSource="{Binding OverviewMatrix}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,2">
                                    <Border Padding="10,6" Margin="1,8,1,4" CornerRadius="4"
                                            Background="#DDE6EF" BorderBrush="#94A3B8" BorderThickness="1,2,1,1"
                                            Visibility="{Binding IsSectionHeader, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                        <TextBlock Text="{Binding SectionTitle}" FontWeight="SemiBold" FontSize="12"/>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2"
                                                Visibility="{Binding ShowsDayHeaders, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                        <Border Width="120" MinWidth="120" Margin="1" Padding="4,8" Background="#F1F5F9"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DataContext.OverviewRowHeader, RelativeSource={RelativeSource AncestorType=views:OverviewView}}"
                                                           FontWeight="SemiBold" FontSize="11"
                                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                                                <TextBlock Text="уроки ↓" FontSize="9" Foreground="{StaticResource MutedTextBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding DataContext.OverviewColumns, RelativeSource={RelativeSource AncestorType=views:OverviewView}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="116" MinWidth="116" Margin="1" Padding="4,6"
                                                            Background="{Binding HeaderBackground}"
                                                            BorderBrush="{Binding HeaderBorderBrush}" BorderThickness="1"
                                                            CornerRadius="4">
                                                        <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                                                   TextAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="Margin" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTrackGroupEnd}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#64748B"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasRowSeparatorBelow}" Value="False">
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Margin" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDayHeaderRow}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" MinWidth="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource OverviewRowHeaderButtonStyle}"
                                                Command="{Binding DataContext.DrillOverviewRowCommand, RelativeSource={RelativeSource AncestorType=views:OverviewView}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Открыть срез по строке">
                                            <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="0,0,1,0" Padding="2,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="4" Margin="0,2,0,2"
                                                        Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                                        Visibility="{Binding BuildingColorHex, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding RowLabel}" FontWeight="SemiBold" FontSize="11"
                                                               TextAlignment="Center" TextWrapping="Wrap" MaxHeight="36"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding RowSubLabel}" FontSize="9"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextAlignment="Center" TextWrapping="Wrap"
                                                               Visibility="{Binding RowSubLabel, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                                </StackPanel>
                                            </Grid>
                                            </Border>
                                        </Button>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="116" MinWidth="116" Margin="1" Padding="1"
                                                            Background="{Binding ColumnBackground}"
                                                            BorderBrush="{Binding ColumnBorderBrush}" BorderThickness="1"
                                                            CornerRadius="4">
                                                        <ItemsControl ItemsSource="{Binding Lessons}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Height="{Binding CellHeight}" Width="116"
                                                                            Margin="0,0,0,1"
                                                                            BorderBrush="#CBD5E1"
                                                                            BorderThickness="0,0,0,1"
                                                                            ToolTip="{Binding ToolTipText}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background"
                                                                                        Value="{Binding DataContext.ColumnBackground, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=1}}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsBreakColumn}" Value="True">
                                                                                        <Setter Property="Background" Value="#FFF8E7"/>
                                                                                        <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsDynamicPauseColumn}" Value="True">
                                                                                        <Setter Property="Background" Value="#ECFDF3"/>
                                                                                        <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                                                                    </DataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                                                                            <Condition Binding="{Binding IsBreakColumn}" Value="False"/>
                                                                                            <Condition Binding="{Binding IsDynamicPauseColumn}" Value="False"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Background" Value="#FAF5FF"/>
                                                                                        <Setter Property="BorderBrush" Value="#DDD6FE"/>
                                                                                    </MultiDataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                                                                            <Condition Binding="{Binding IsBreakColumn}" Value="True"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                                                                    </MultiDataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsSecondShiftColumn}" Value="True"/>
                                                                                            <Condition Binding="{Binding IsDynamicPauseColumn}" Value="True"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                                                                    </MultiDataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsShiftBoundaryRow}" Value="True">
                                                                                        <Setter Property="BorderThickness" Value="0,3,0,1"/>
                                                                                        <Setter Property="BorderBrush" Value="#7C3AED"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="14"/>
                                                                                <RowDefinition Height="*"/>
                                                                            </Grid.RowDefinitions>
                                                                            <TextBlock Grid.Row="0" Text="{Binding TimeLabel}" FontSize="8"
                                                                                       TextAlignment="Center" VerticalAlignment="Center">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsBreakColumn}" Value="True">
                                                                                                <Setter Property="Foreground" Value="#B45309"/>
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsDynamicPauseColumn}" Value="True">
                                                                                                <Setter Property="Foreground" Value="#15803D"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Parts}"
                                                                                          Visibility="{Binding HasContent, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <StackPanel Orientation="Vertical"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Button Style="{StaticResource OverviewTimelinePartButtonStyle}"
                                                                                                Command="{Binding DataContext.DrillOverviewPartCommand, RelativeSource={RelativeSource AncestorType=views:OverviewView}}"
                                                                                                CommandParameter="{Binding}"
                                                                                                ToolTip="{Binding ToolTipText}">
                                                                                            <StackPanel>
                                                                                                <TextBlock FontSize="8" FontWeight="Bold"
                                                                                                           Foreground="{StaticResource PrimaryBrush}"
                                                                                                           HorizontalAlignment="Center"
                                                                                                           Text="{Binding SubgroupLabel, StringFormat=[{0}]}"
                                                                                                           Visibility="{Binding SubgroupLabel, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                                                                                                <TextBlock Text="{Binding SubjectLine}" FontSize="8"
                                                                                                           FontWeight="SemiBold" TextAlignment="Center"
                                                                                                           Foreground="#7C3AED"
                                                                                                           TextWrapping="Wrap" LineStackingStrategy="BlockLineHeight"
                                                                                                           LineHeight="11"/>
                                                                                                <TextBlock Text="{Binding TeacherLine}" FontSize="7"
                                                                                                           Foreground="#0369A1"
                                                                                                           TextAlignment="Center"
                                                                                                           TextWrapping="Wrap" LineHeight="10"/>
                                                                                                <TextBlock Text="{Binding RoomLine}" FontSize="7"
                                                                                                           TextAlignment="Center"
                                                                                                           TextWrapping="Wrap" LineHeight="10"
                                                                                                           Foreground="{Binding RoomBuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                                                                                           Visibility="{Binding HasRoomLine, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                                                                            </StackPanel>
                                                                                        </Button>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Margin="12" Padding="16" CornerRadius="8"
                    Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1"
                    VerticalAlignment="Top"
                    Visibility="{Binding OverviewEmptyHint, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}">
                <TextBlock Text="{Binding OverviewEmptyHint}" TextWrapping="Wrap"
                           Foreground="#9A3412" FontSize="12"/>
            </Border>

            <Border Background="#FAFBFC"
                    Visibility="{Binding IsOverviewEmpty, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                    <TextBlock Text="Нет строк для отображения" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding OverviewEmptyHint}" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
