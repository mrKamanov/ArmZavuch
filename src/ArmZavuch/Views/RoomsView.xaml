<UserControl x:Class="ArmZavuch.Views.RoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ArmZavuch.Views.Converters"
             xmlns:models="clr-namespace:ArmZavuch.Models">
    <UserControl.Resources>
        <DataTemplate x:Key="RoomBlockTemplate">
            <Border MinHeight="68" MaxHeight="80" CornerRadius="4" ToolTip="{Binding ToolTip}"
                    Width="{Binding WidthPixels}" Margin="0,1,0,1" Padding="4,3">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FEE2E2"/>
                        <Setter Property="BorderBrush" Value="#F87171"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDynamicPause}" Value="True">
                                <Setter Property="Background" Value="#DCFCE7"/>
                                <Setter Property="BorderBrush" Value="#4ADE80"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimeDisplay}" FontSize="9" FontWeight="Bold"
                               TextAlignment="Center" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#991B1B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDynamicPause}" Value="True">
                                        <Setter Property="Foreground" Value="#166534"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding PrimaryLine}" FontSize="9" FontWeight="SemiBold"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SecondaryLine}" FontSize="8"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding TeacherLine}" FontSize="8" FontStyle="Italic"
                               Foreground="#64748B" TextAlignment="Center" TextWrapping="Wrap"
                               Visibility="{Binding TeacherLine, Converter={x:Static conv:EmptyToCollapsedConverter.Instance}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="RoomTimelineHourBandTemplate">
            <Rectangle Height="72" Width="{Binding WidthPixels}"
                       Fill="{Binding BackgroundHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
        </DataTemplate>

        <DataTemplate x:Key="RoomTimelineGridLineTemplate">
            <Line X1="0" X2="0" Y1="0" Y2="72" SnapsToDevicePixels="True">
                <Line.Style>
                    <Style TargetType="Line">
                        <Setter Property="Stroke" Value="#E2E8F0"/>
                        <Setter Property="StrokeThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMajor}" Value="True">
                                <Setter Property="Stroke" Value="#CBD5E1"/>
                                <Setter Property="StrokeThickness" Value="1.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>
        </DataTemplate>

        <DataTemplate x:Key="RoomTimelineHeaderHourBandTemplate">
            <Rectangle Height="32" Width="{Binding WidthPixels}"
                       Fill="{Binding BackgroundHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
        </DataTemplate>

        <DataTemplate x:Key="RoomTimelineHeaderTickTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Label}" FontSize="9"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="-12,0,0,0" Width="28" TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMajor}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Line X1="0" X2="0" Y1="18" Y2="32"
                      Stroke="#CBD5E1" StrokeThickness="1" SnapsToDevicePixels="True">
                    <Line.Style>
                        <Style TargetType="Line">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMajor}" Value="True">
                                    <Setter Property="Stroke" Value="#94A3B8"/>
                                    <Setter Property="StrokeThickness" Value="1.5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Line.Style>
                </Line>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="RoomRowTemplate">
            <Grid Margin="0,2"
                  Visibility="{Binding IsHidden, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="2,0,4,0" Padding="0" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" VerticalAlignment="Stretch">
                    <Border BorderThickness="4,0,0,0"
                            BorderBrush="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearchResult}" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Margin="6,4,6,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RoomNumber}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding BuildingName}" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}">
                                <Run Text="{Binding Capacity, Mode=OneWay}"/>
                                <Run Text=" мест"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Border>
                <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1,0,1,0" ClipToBounds="True">
                <Canvas Width="{Binding TimelineWidthPixels}" Height="72">
                    <ItemsControl ItemsSource="{Binding DataContext.TimelineHourBands, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ItemTemplate="{StaticResource RoomTimelineHourBandTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding LeftPixels}"/>
                                <Setter Property="Canvas.Top" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding DataContext.TimelineTicks, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ItemTemplate="{StaticResource RoomTimelineGridLineTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding LeftPixels}"/>
                                <Setter Property="Canvas.Top" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                    <Border Canvas.Left="{Binding SearchBandLeft}" Width="{Binding SearchBandWidth}"
                            Height="72" Background="#BFDBFE" Opacity="0.35" CornerRadius="2"
                            Visibility="{Binding ShowSearchBand, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                    <ItemsControl ItemsSource="{Binding Blocks}" ItemTemplate="{StaticResource RoomBlockTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding LeftPixels}"/>
                                <Setter Property="Canvas.Top" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Canvas>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="360"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="300" MinWidth="260" MaxWidth="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource ModuleHeaderBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Кабинеты" Style="{StaticResource ModulePageTitleStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Дата:" Style="{StaticResource FormFieldLabelStyle}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker SelectedDate="{Binding SelectedDate}" Width="140"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Здание:" Style="{StaticResource FormFieldLabelStyle}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding BuildingNames}" SelectedItem="{Binding SelectedBuildingFilter}"
                                  Width="180" ToolTip="Фильтр шахматки по зданию"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DayStatusText}" Margin="16,0,0,0" VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource ToolbarButtonGroupStyle}">
                    <Button Style="{StaticResource ToolbarGroupItemStyle}" Command="{Binding RefreshCommand}"
                            ToolTip="Обновить шахматку (F5)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Обновить" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#FAFBFC"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#F1F5F9" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="4,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Кабинет" FontWeight="SemiBold" FontSize="11"/>
                                <TextBlock Text="{Binding TimelineRangeLabel}" FontSize="9"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                            <Canvas Grid.Column="1" Width="{Binding TimelineWidthPixels}" Height="32"
                                    Background="Transparent" ClipToBounds="True">
                                <ItemsControl ItemsSource="{Binding TimelineHourBands}"
                                              ItemTemplate="{StaticResource RoomTimelineHeaderHourBandTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding LeftPixels}"/>
                                            <Setter Property="Canvas.Top" Value="0"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding TimelineTicks}"
                                              ItemTemplate="{StaticResource RoomTimelineHeaderTickTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding LeftPixels}"/>
                                            <Setter Property="Canvas.Top" Value="0"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                </ItemsControl>
                            </Canvas>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding BuildingGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:RoomBuildingGroup}">
                                <StackPanel Margin="0,0,0,6">
                                    <Border Background="#E2E8F0" CornerRadius="6" Padding="8,5" Margin="2,4,2,4">
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Left" Width="24" Height="24" Padding="0" Margin="0,0,8,0"
                                                    FontSize="11" Cursor="Hand"
                                                    Command="{Binding DataContext.ToggleBuildingGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Свернуть или развернуть здание">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
                                                        <Setter Property="MinWidth" Value="24"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding CollapseToggleGlyph}" HorizontalAlignment="Center"/>
                                            </Button>
                                            <Border DockPanel.Dock="Left" Width="4" Margin="0,0,8,0" CornerRadius="2"
                                                    Background="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BuildingName}" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Margin="8,0,0,0" FontSize="11"
                                                           Foreground="{StaticResource MutedTextBrush}">
                                                    <Run Text="{Binding RoomCount, Mode=OneWay}"/>
                                                    <Run Text=" каб."/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Rooms}"
                                                  ItemTemplate="{StaticResource RoomRowTemplate}"
                                                  Visibility="{Binding AreRoomsVisible, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Row="1" Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource DirectorySidePanelStyle}">
            <DockPanel LastChildFill="True">
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled" MaxHeight="480">
                    <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Поиск свободного кабинета" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="По номеру урока (1 класс или 2–11) или по диапазону времени. На шкале подсветится интервал, свободные кабинеты — синим."
                               FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <CheckBox IsChecked="{Binding UseTimeRangeSearch}" Content="Искать по времени (диапазон)"
                              FontSize="11" Margin="0,0,0,6"/>

                    <Border Style="{StaticResource SidePanelHelpBoxStyle}" Margin="0,0,0,8"
                            Visibility="{Binding UseTimeRangeSearch, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding TimeRangeSearchHint}"
                                   Style="{StaticResource SidePanelHelpTextStyle}" Margin="0"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Grid Margin="0,0,0,8"
                          Visibility="{Binding UseTimeRangeSearch, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="С (начало)" Style="{StaticResource FormFieldLabelStyle}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding SearchTimeFromText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Начало интервала, например 09:15"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="По (конец)" Style="{StaticResource FormFieldLabelStyle}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding SearchTimeToText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Конец интервала, например 09:50"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8"
                          Visibility="{Binding UseTimeRangeSearch, Converter={x:Static conv:InverseBoolToVisibilityConverter.Instance}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Урок" Style="{StaticResource FormFieldLabelStyle}" Margin="0,0,0,2"/>
                            <ComboBox ItemsSource="{Binding LessonNumbers}" SelectedItem="{Binding SearchLesson}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Сетка звонков" Style="{StaticResource FormFieldLabelStyle}" Margin="0,0,0,2"/>
                            <ComboBox ItemsSource="{Binding GradeBandOptions}"
                                      SelectedItem="{Binding SelectedGradeBand}"
                                      DisplayMemberPath="DisplayName"
                                      ToolTip="1 класс — с дин. паузами; 2–11 — стандартная сетка"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox IsChecked="{Binding UseCapacityFilter}" Content="Учитывать минимум мест"
                              FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Margin="0,0,0,8"
                                Visibility="{Binding UseCapacityFilter, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <TextBlock Text="Мин. мест" Style="{StaticResource FormFieldLabelStyle}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MinCapacityText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Здание" Style="{StaticResource FormFieldLabelStyle}" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding BuildingNames}" SelectedItem="{Binding SelectedSearchBuilding}"/>
                    </StackPanel>

                    <Border Style="{StaticResource ToolbarButtonGroupStyle}" Margin="0,0,0,8">
                        <WrapPanel Orientation="Horizontal">
                            <Button Style="{StaticResource ToolbarGroupPrimaryItemStyle}"
                                    Command="{Binding SearchFreeCommand}" Margin="0,0,0,4">
                                <TextBlock Text="Найти" VerticalAlignment="Center"/>
                            </Button>
                            <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                            <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                    Command="{Binding ClearSearchCommand}"
                                    ToolTip="Сбросить поиск и подсветку" Margin="0,0,0,4">
                                <TextBlock Text="Сброс" VerticalAlignment="Center"/>
                            </Button>
                            <Border Style="{StaticResource ToolbarGroupSeparatorStyle}"/>
                            <Button Style="{StaticResource ToolbarGroupItemStyle}"
                                    Command="{Binding ToggleShowOnlyFreeCommand}"
                                    ToolTip="Показать в шахматке только найденные кабинеты" Margin="0,0,0,4">
                                <TextBlock Text="Только найденные" VerticalAlignment="Center" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Button>
                        </WrapPanel>
                    </Border>
                    <TextBlock Text="{Binding SearchSummary}" FontSize="11" FontWeight="SemiBold"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                    </StackPanel>
                </ScrollViewer>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FreeRooms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="0" CornerRadius="6"
                                        Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1">
                                    <Border BorderThickness="4,0,0,0"
                                            BorderBrush="{Binding BuildingColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}">
                                        <StackPanel Margin="8,6,8,6">
                                            <TextBlock FontWeight="SemiBold" FontSize="12">
                                                <Run Text="каб. "/>
                                                <Run Text="{Binding Number, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}">
                                                <Run Text="{Binding BuildingName, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Capacity, Mode=OneWay}"/>
                                                <Run Text=" мест"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
